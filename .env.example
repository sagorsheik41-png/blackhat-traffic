# ─── Firebase Configuration ────────────────────────────────
# Get these from your Firebase Console: https://console.firebase.google.com

FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin SDK - Service Account JSON (paste your entire service account JSON here, minified)
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"omni-64c5c","private_key_id":"KEY_ID","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Service Account Path (alternative to FIREBASE_SERVICE_ACCOUNT_JSON)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-credentials.json

# ─── Server Configuration ───────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=localhost

# ─── Database Configuration (Optional - for hybrid setup) ───
MONGODB_URI=mongodb://localhost:27017/blackhat-traffic
MONGODB_MEMORY_SERVER=false

# ─── JWT Configuration ─────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ─── Session Configuration ────────────────────────────────
SESSION_SECRET=your-session-secret-change-this-in-production

# ─── API Keys (Optional) ────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key
GEMINI_API_KEY=your_gemini_api_key
TRAFFIC_API_KEY=your_traffic_api_key
OLLAMA_API_KEY=f5a80934188c41bc979a1fe810015e89._9ffcVpaev6VcsaDlrLKaXwo

# ─── Email Configuration (Optional) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@blackhat-traffic.com

# ─── Stripe Configuration (Optional) ────────────────────────
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# ─── Payment Gateway Configuration ─────────────────────────
BKASH_API_KEY=your_bkash_api_key
BKASH_SECRET_KEY=your_bkash_secret_key
NAGAD_API_KEY=your_nagad_api_key
ROCKET_API_KEY=your_rocket_api_key

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# ─── CORS Configuration ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── Security ───────────────────────────────────────────────
BCRYPT_ROUNDS=12
TOKEN_SALT_ROUNDS=10

# ─── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=2000
AUTH_RATE_LIMIT_MAX=1000
