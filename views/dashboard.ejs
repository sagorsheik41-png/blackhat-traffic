<!-- Omni-Dashboard -->
<div class="space-y-6">

    <!-- Welcome Banner -->
    <div class="glass-card p-6 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-indigo-600/20 to-purple-600/20"></div>
        <div class="relative z-10">
            <h1 class="text-2xl font-bold text-white mb-2">
                Welcome back, <span class="text-indigo-400">
                    <%= user.name %>
                </span>! 👋
            </h1>
            <p class="text-gray-400">Your all-in-one command center for digital marketing, trading, and content
                creation.</p>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="glass-card p-4 text-center">
            <div class="text-3xl font-bold text-indigo-400 mb-1">10</div>
            <div class="text-xs text-gray-400 font-semibold uppercase">Tools Available</div>
        </div>
        <div class="glass-card p-4 text-center">
            <div class="text-3xl font-bold text-green-400 mb-1 capitalize">
                <%= user.tier %>
            </div>
            <div class="text-xs text-gray-400 font-semibold uppercase">Current Plan</div>
        </div>
        <div class="glass-card p-4 text-center">
            <div class="text-3xl font-bold text-purple-400 mb-1">
                <%= user.role==='admin' ? 'Admin' : 'User' %>
            </div>
            <div class="text-xs text-gray-400 font-semibold uppercase">Role</div>
        </div>
        <div class="glass-card p-4 text-center">
            <div class="text-3xl font-bold text-yellow-400 mb-1">
                <%= recentActivity.length %>
            </div>
            <div class="text-xs text-gray-400 font-semibold uppercase">Recent Actions</div>
        </div>
    </div>

    <!-- Quick Launch Grid -->
    <div class="glass-card p-6">
        <h2 class="text-lg font-bold text-white mb-4"><i class="fas fa-rocket mr-2 text-indigo-400"></i>Quick Launch
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3">

            <a href="/tools/adobe-stock"
                class="group p-4 rounded-xl bg-white/5 hover:bg-indigo-600/20 transition-all text-center border border-white/5 hover:border-indigo-500/30">
                <i
                    class="fas fa-palette text-2xl text-indigo-400 mb-2 group-hover:scale-110 transition-transform inline-block"></i>
                <div class="text-xs font-semibold text-gray-300">Adobe Stock</div>
            </a>

            <a href="/tools/traffic-pro"
                class="group p-4 rounded-xl bg-white/5 hover:bg-green-600/20 transition-all text-center border border-white/5 hover:border-green-500/30">
                <i
                    class="fas fa-chart-line text-2xl text-green-400 mb-2 group-hover:scale-110 transition-transform inline-block"></i>
                <div class="text-xs font-semibold text-gray-300">Traffic Pro</div>
            </a>

            <a href="/tools/trading-bot"
                class="group p-4 rounded-xl bg-white/5 hover:bg-yellow-600/20 transition-all text-center border border-white/5 hover:border-yellow-500/30">
                <i
                    class="fas fa-robot text-2xl text-yellow-400 mb-2 group-hover:scale-110 transition-transform inline-block"></i>
                <div class="text-xs font-semibold text-gray-300">AI Trading</div>
            </a>

            <a href="/tools/multi-device"
                class="group p-4 rounded-xl bg-white/5 hover:bg-sky-600/20 transition-all text-center border border-white/5 hover:border-sky-500/30">
                <i
                    class="fas fa-mobile-alt text-2xl text-sky-400 mb-2 group-hover:scale-110 transition-transform inline-block"></i>
                <div class="text-xs font-semibold text-gray-300">Multi-Device</div>
            </a>

            <a href="/tools/movie-stream"
                class="group p-4 rounded-xl bg-white/5 hover:bg-pink-600/20 transition-all text-center border border-white/5 hover:border-pink-500/30">
                <i
                    class="fas fa-film text-2xl text-pink-400 mb-2 group-hover:scale-110 transition-transform inline-block"></i>
                <div class="text-xs font-semibold text-gray-300">Movies</div>
            </a>

            <a href="/tools/signals"
                class="group p-4 rounded-xl bg-white/5 hover:bg-red-600/20 transition-all text-center border border-white/5 hover:border-red-500/30">
                <i
                    class="fas fa-signal text-2xl text-red-400 mb-2 group-hover:scale-110 transition-transform inline-block"></i>
                <div class="text-xs font-semibold text-gray-300">Signals</div>
            </a>

            <a href="/tools/youtube"
                class="group p-4 rounded-xl bg-white/5 hover:bg-red-600/20 transition-all text-center border border-white/5 hover:border-red-500/30">
                <i
                    class="fab fa-youtube text-2xl text-red-500 mb-2 group-hover:scale-110 transition-transform inline-block"></i>
                <div class="text-xs font-semibold text-gray-300">YouTube</div>
            </a>

            <a href="/tools/link-tools"
                class="group p-4 rounded-xl bg-white/5 hover:bg-cyan-600/20 transition-all text-center border border-white/5 hover:border-cyan-500/30">
                <i
                    class="fas fa-link text-2xl text-cyan-400 mb-2 group-hover:scale-110 transition-transform inline-block"></i>
                <div class="text-xs font-semibold text-gray-300">Link Tools</div>
            </a>

            <a href="/tools/calculator"
                class="group p-4 rounded-xl bg-white/5 hover:bg-purple-600/20 transition-all text-center border border-white/5 hover:border-purple-500/30">
                <i
                    class="fas fa-calculator text-2xl text-purple-400 mb-2 group-hover:scale-110 transition-transform inline-block"></i>
                <div class="text-xs font-semibold text-gray-300">Calculator</div>
            </a>

            <a href="/tools/crypto-mining"
                class="group p-4 rounded-xl bg-white/5 hover:bg-emerald-600/20 transition-all text-center border border-white/5 hover:border-emerald-500/30">
                <i
                    class="fab fa-ethereum text-2xl text-emerald-400 mb-2 group-hover:scale-110 transition-transform inline-block"></i>
                <div class="text-xs font-semibold text-gray-300">Crypto</div>
            </a>

        </div>
    </div>

    <!-- Recent Activity -->
    <div class="glass-card p-6">
        <h2 class="text-lg font-bold text-white mb-4"><i class="fas fa-history mr-2 text-green-400"></i>Recent Activity
        </h2>
        <% if (recentActivity.length> 0) { %>
            <div class="space-y-2 max-h-64 overflow-y-auto">
                <% recentActivity.forEach(function(log) { %>
                    <div class="flex items-center gap-3 p-3 rounded-lg bg-white/5 border border-white/5">
                        <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm 
          <%= log.action === 'login' ? 'bg-green-600/20 text-green-400' : 
             log.action === 'register' ? 'bg-blue-600/20 text-blue-400' : 
             log.action === 'tool_access' ? 'bg-purple-600/20 text-purple-400' : 
             'bg-gray-600/20 text-gray-400' %>">
                            <i class="fas <%= log.action === 'login' ? 'fa-sign-in-alt' : 
                           log.action === 'register' ? 'fa-user-plus' : 
                           log.action === 'logout' ? 'fa-sign-out-alt' : 
                           'fa-cog' %>"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="text-sm font-medium text-gray-300 capitalize">
                                <%= log.action.replace('_', ' ' ) %>
                            </div>
                            <div class="text-xs text-gray-500">
                                <%= log.details || '' %>
                            </div>
                        </div>
                        <div class="text-xs text-gray-500">
                            <%= new Date(log.createdAt).toLocaleString() %>
                        </div>
                    </div>
                    <% }); %>
            </div>
            <% } else { %>
                <div class="text-center py-8 text-gray-500">
                    <i class="fas fa-inbox text-4xl mb-3 block"></i>
                    <p>No recent activity yet. Start using the tools!</p>
                </div>
                <% } %>
    </div>

</div>