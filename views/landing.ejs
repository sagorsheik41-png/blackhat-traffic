<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OmniCore OS | The Ultimate 19-in-1 Marketing & Trading Suite</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --primary: #6366f1;
            --secondary: #a855f7;
            --dark: #020617;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        body {
            background: var(--dark);
            color: white;
            overflow-x: hidden;
            scroll-behavior: smooth;
        }

        .glass {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .hero-glow {
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            height: 600px;
            background: radial-gradient(circle at center, rgba(99, 102, 241, 0.15) 0%, transparent 70%);
            z-index: -1;
        }

        .animate-float {
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-20px);
            }
        }

        .tool-card {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
        }

        .tool-card:hover {
            transform: translateY(-10px);
            border-color: var(--primary);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(99, 102, 241, 0.2);
        }

        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s ease-out;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>

<body class="selection:bg-indigo-500/30">
    <div class="hero-glow"></div>

    <!-- Navbar -->
    <nav class="fixed top-0 w-full z-50 px-6 py-6 transition-all duration-300">
        <div class="max-w-7xl mx-auto flex justify-between items-center glass px-8 py-4 rounded-3xl">
            <div class="flex items-center gap-3">
                <div
                    class="w-10 h-10 rounded-2xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center shadow-lg shadow-indigo-500/20">
                    <i class="fas fa-bolt text-white text-lg"></i>
                </div>
                <span class="text-xl font-extrabold tracking-tight">OmniCore <span
                        class="text-indigo-400">OS</span></span>
            </div>
            <div class="hidden md:flex items-center gap-8">
                <a href="#tools" class="text-sm font-bold text-gray-400 hover:text-white transition-colors">19-in-1
                    Suite</a>
                <a href="#pricing"
                    class="text-sm font-bold text-gray-400 hover:text-white transition-colors">Pricing</a>
                <div class="h-4 w-[1px] bg-white/10"></div>
                <a href="/auth/login" class="text-sm font-bold text-gray-400 hover:text-white">Sign In</a>
                <a href="/auth/register"
                    class="bg-white text-dark px-6 py-2.5 rounded-xl font-bold hover:scale-105 transition-all text-sm">Get
                    Started</a>
            </div>
        </div>
    </nav>

    <!-- Hero -->
    <section class="pt-48 pb-32 px-6">
        <div class="max-w-6xl mx-auto text-center">
            <div
                class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-[10px] font-black tracking-widest text-indigo-400 mb-8 animate-pulse uppercase">
                <i class="fas fa-certificate"></i> Certified Ultimate Commercial Suite
            </div>
            <h1 class="text-6xl md:text-8xl font-black mb-8 tracking-tighter leading-[0.85]">
                UNLEASH THE <br>
                <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-purple-400 to-teal-400">ULTIMATE
                    CORE</span>
            </h1>
            <p class="text-xl text-gray-400 max-w-3xl mx-auto mb-12 leading-relaxed font-medium">
                The web's most powerful 19-in-1 Digital Marketing, Trading & Automation ecosystem.
                Everything from AI Trading and Matrix-grade Traffic to Adobe Metadata Mastery.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <a href="/auth/register"
                    class="w-full sm:w-auto px-10 py-5 bg-indigo-600 text-white font-black rounded-2xl hover:bg-indigo-500 hover:scale-105 transition-all flex items-center justify-center gap-3 group">
                    Start Your Empire <i class="fas fa-rocket group-hover:translate-x-1 transition-transform"></i>
                </a>
                <a href="#tools"
                    class="w-full sm:w-auto px-10 py-5 glass text-white font-bold rounded-2xl hover:bg-white/10 transition-all">Explore
                    19 Tools</a>
            </div>
        </div>
    </section>

    <!-- Tools Showcase -->
    <section id="tools" class="py-32 px-6 relative">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-20">
                <h2 class="text-4xl font-black mb-4 reveal">One Platform. <span class="text-indigo-400">Infinite
                        Power.</span></h2>
                <p class="text-gray-500 font-medium reveal">19 high-performance tools consolidated into 10 specialized
                    categories.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Tool Category 1 -->
                <div class="tool-card glass p-8 rounded-3xl hover:border-indigo-500/50 reveal">
                    <div
                        class="w-14 h-14 rounded-2xl bg-indigo-500/10 flex items-center justify-center mb-6 border border-indigo-500/20">
                        <i class="fas fa-chart-line text-indigo-400 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3">AI Trading Intelligence</h3>
                    <p class="text-gray-400 text-sm leading-relaxed mb-6">Real-time market signals, predictive
                        algorithms, and high-win probability markers.</p>
                    <div class="flex gap-2"><span
                            class="text-[9px] font-black px-2 py-1 bg-white/5 rounded-lg border border-white/5 uppercase">Signals</span>
                    </div>
                </div>

                <!-- Tool Category 2 -->
                <div class="tool-card glass p-8 rounded-3xl hover:border-purple-500/50 reveal">
                    <div
                        class="w-14 h-14 rounded-2xl bg-purple-500/10 flex items-center justify-center mb-6 border border-purple-500/20">
                        <i class="fas fa-bolt text-purple-400 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3">Traffic Pro Engine</h3>
                    <p class="text-gray-400 text-sm leading-relaxed mb-6">Matrix-level traffic simulation, proxy
                        rotation, and automated engagement loops.</p>
                    <div class="flex gap-2"><span
                            class="text-[9px] font-black px-2 py-1 bg-white/5 rounded-lg border border-white/5 uppercase">Traffic</span>
                    </div>
                </div>

                <!-- Tool Category 3 -->
                <div class="tool-card glass p-8 rounded-3xl hover:border-sky-500/50 reveal">
                    <div
                        class="w-14 h-14 rounded-2xl bg-sky-500/10 flex items-center justify-center mb-6 border border-sky-500/20">
                        <i class="fas fa-camera text-sky-400 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3">Adobe Stock Mastery</h3>
                    <p class="text-gray-400 text-sm leading-relaxed mb-6">5 tools in 1: Titles, Keywords, Color
                        Palettes, and Batch Metadata ZIP extraction.</p>
                    <div class="flex gap-2"><span
                            class="text-[9px] font-black px-2 py-1 bg-white/5 rounded-lg border border-white/5 uppercase">Creative</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="py-32 px-6">
        <div class="max-w-5xl mx-auto text-center mb-20">
            <h2 class="text-4xl font-black mb-4 reveal">Commercial License Plans</h2>
            <p class="text-gray-500 font-medium reveal">Choose the tier that fits your growth trajectory.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
            <!-- Pro -->
            <div
                class="glass p-10 rounded-3xl border-2 border-indigo-500/20 hover:border-indigo-500 transition-all reveal relative">
                <div
                    class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 bg-indigo-600 rounded-full text-[10px] font-black uppercase">
                    Standard Choice</div>
                <h3 class="text-2xl font-black mb-2">Professional</h3>
                <div class="text-5xl font-black mb-6">
                    <% if (settings.useBDT) { %>৳<%= settings.pricingBDT.pro %>
                            <% } else { %>$<%= settings.pricing.pro %>
                                    <% } %>
                                        <span class="text-sm font-medium text-gray-500">/mo</span>
                </div>
                <ul class="text-left space-y-4 mb-8 text-sm text-gray-400">
                    <li class="flex items-center gap-3"><i class="fas fa-check text-green-500"></i> Full AI Trading
                        Suite</li>
                    <li class="flex items-center gap-3"><i class="fas fa-check text-green-500"></i> Traffic Pro Basic
                    </li>
                    <li class="flex items-center gap-3"><i class="fas fa-check text-green-500"></i> Unlimited
                        Multi-Device</li>
                    <li class="flex items-center gap-3"><i class="fas fa-check text-green-500"></i> Priority Email
                        Support</li>
                </ul>
                <a href="/auth/register"
                    class="block py-4 bg-indigo-600 hover:bg-indigo-500 rounded-2xl font-black transition-all">Select
                    Pro</a>
            </div>

            <!-- Ultimate -->
            <div
                class="glass p-10 rounded-3xl border-2 border-purple-500/20 hover:border-purple-500 transition-all reveal relative">
                <div
                    class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 bg-purple-600 rounded-full text-[10px] font-black uppercase">
                    Max Dominance</div>
                <h3 class="text-2xl font-black mb-2">Ultimate</h3>
                <div class="text-5xl font-black mb-6">
                    <% if (settings.useBDT) { %>৳<%= settings.pricingBDT.ultimate %>
                            <% } else { %>$<%= settings.pricing.ultimate %>
                                    <% } %>
                                        <span class="text-sm font-medium text-gray-500">/mo</span>
                </div>
                <ul class="text-left space-y-4 mb-8 text-sm text-gray-400">
                    <li class="flex items-center gap-3"><i class="fas fa-check text-purple-500"></i> All 19 Professional
                        Modules</li>
                    <li class="flex items-center gap-3"><i class="fas fa-check text-purple-500"></i> White-label API
                        Access</li>
                    <li class="flex items-center gap-3"><i class="fas fa-check text-purple-500"></i> 24/7 Priority
                        Concierge</li>
                    <li class="flex items-center gap-3 font-bold text-white"><i class="fas fa-lock text-purple-500"></i>
                        Secured Owner Protocol</li>
                </ul>
                <a href="/auth/register"
                    class="block py-4 bg-purple-600 hover:bg-purple-500 rounded-2xl font-black transition-all">Select
                    Ultimate</a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="pt-32 pb-10 border-t border-white/5">
        <div class="max-w-7xl mx-auto px-6 text-center">
            <div class="flex items-center justify-center gap-3 mb-8">
                <div class="w-8 h-8 rounded-xl bg-indigo-600 flex items-center justify-center font-black">O</div>
                <span class="font-extrabold text-xl">OmniCore OS</span>
            </div>
            <p class="text-gray-500 text-xs font-semibold mb-8 uppercase tracking-widest">A Commercial Traffic & Trading
                Suite by BlackHat Traffic Inc.</p>
            <div class="flex justify-center gap-8 text-xs font-bold text-gray-600 mb-8">
                <a href="#" class="hover:text-white">Terms</a>
                <a href="#" class="hover:text-white">Policy</a>
                <a href="#" class="hover:text-white">Help</a>
            </div>
            <p class="text-[10px] text-gray-700">© 2026 Developed for Commercial Domination. All Rights Reserved.</p>
        </div>
    </footer>

    <script>
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('active'); });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
</body>

</html>