<div class="flex items-center justify-center min-h-[60vh]">
    <div class="text-center glass-card p-10 max-w-md">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-yellow-500/20 flex items-center justify-center">
            <i class="fas fa-crown text-3xl text-yellow-400"></i>
        </div>
        <h2 class="text-2xl font-bold text-white mb-2">Upgrade Required</h2>
        <p class="text-gray-400 mb-4">This feature requires the <span class="font-bold text-yellow-400 uppercase">
                <%= requiredTier %>
            </span> plan.</p>
        <p class="text-sm text-gray-500 mb-6">You're currently on the <span class="capitalize font-semibold">
                <%= currentTier %>
            </span> plan.</p>
        <a href="/dashboard/upgrade"
            class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-yellow-500 to-orange-500 text-white font-bold rounded-xl hover:shadow-lg transition-all">
            <i class="fas fa-arrow-up"></i> Upgrade Now
        </a>
    </div>
</div>