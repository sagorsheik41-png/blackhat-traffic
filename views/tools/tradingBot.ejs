<div class="px-4 py-8 max-w-7xl mx-auto min-h-screen relative overflow-hidden">
    <!-- Live Status Badge -->
    <div
        class="absolute top-4 right-4 bg-emerald-500/20 border border-emerald-500/50 text-emerald-300 px-4 py-2 rounded-full font-bold text-sm z-50 flex items-center shadow-[0_0_15px_rgba(16,185,129,0.3)]">
        <div class="w-2 h-2 bg-white rounded-full mr-2 animate-pulse"></div>
        LIVE AI TRADING
    </div>

    <!-- Header Section -->
    <div class="flex flex-col mb-8 gap-4 mt-8 md:mt-0">
        <div>
            <h1
                class="text-3xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-blue-500 mb-2">
                Black Hat AI Trading Bot</h1>
            <p class="text-gray-400">Advanced AI Signals • Automated Trading • Premium Access</p>
        </div>

        <!-- Market Data Ticker -->
        <div class="glass-panel border border-white/10 rounded-xl p-4 overflow-x-auto custom-scrollbar">
            <div id="aiMarketTicker" class="flex gap-6 min-w-max">
                <!-- Populated by JS -->
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Left Column: Trading Setup & Signal -->
        <div class="lg:col-span-1 flex flex-col gap-6">

            <!-- Signal Generator Panel -->
            <div class="glass-panel border border-white/10 rounded-2xl p-6 relative overflow-hidden group">
                <div
                    class="absolute -right-10 -top-10 w-40 h-40 bg-purple-500/10 rounded-full blur-3xl transition-all group-hover:bg-purple-500/20">
                </div>

                <h3 class="text-xl font-bold mb-6 text-white flex items-center">
                    <i class="fas fa-brain text-purple-400 mr-3"></i> AI Signal Engine
                </h3>

                <!-- Platform Selection -->
                <div class="mb-5">
                    <label
                        class="block text-xs text-gray-400 uppercase tracking-widest font-semibold mb-2">Platform</label>
                    <div class="grid grid-cols-2 gap-2" id="aiPlatformSelect">
                        <button class="ai-select-btn active text-sm" data-val="binance"><i
                                class="fab fa-bitcoin mr-1"></i>Binance</button>
                        <button class="ai-select-btn text-sm" data-val="quotex"><i
                                class="fas fa-chart-bar mr-1"></i>Quotex</button>
                        <button class="ai-select-btn text-sm" data-val="pocketoption"><i
                                class="fas fa-hand-pointer mr-1"></i>PocketOption</button>
                        <button class="ai-select-btn text-sm" data-val="exness"><i
                                class="fas fa-exchange-alt mr-1"></i>Exness</button>
                    </div>
                </div>

                <!-- Pair Selection -->
                <div class="mb-5">
                    <label class="block text-xs text-gray-400 uppercase tracking-widest font-semibold mb-2">Trading
                        Pair</label>
                    <select id="aiPairSelect"
                        class="glass-input w-full px-3 py-2 rounded-lg border border-white/10 text-white text-sm bg-gray-900/50">
                        <!-- Populated by JS based on platform -->
                    </select>
                </div>

                <!-- Duration Selection -->
                <div class="mb-6">
                    <label
                        class="block text-xs text-gray-400 uppercase tracking-widest font-semibold mb-2">Duration</label>
                    <div class="grid grid-cols-4 gap-2" id="aiDurationSelect">
                        <button class="ai-select-btn text-xs py-1" data-val="60">1m</button>
                        <button class="ai-select-btn active text-xs py-1" data-val="120">2m</button>
                        <button class="ai-select-btn text-xs py-1" data-val="300">5m</button>
                        <button class="ai-select-btn text-xs py-1" data-val="900">15m</button>
                    </div>
                </div>

                <!-- Signal Display Area -->
                <div id="aiSignalDisplay"
                    class="bg-gray-900/50 border border-white/5 rounded-xl p-4 mb-4 min-h-[140px] flex flex-col justify-center items-center text-center relative overflow-hidden transition-all">
                    <!-- Default State -->
                    <div class="text-gray-500 flex flex-col items-center">
                        <i class="fas fa-satellite-dish text-2xl mb-2 opacity-50"></i>
                        <span class="text-sm">Ready to scan market patterns</span>
                    </div>
                </div>

                <!-- Generate Action -->
                <% if (user.tier==='pro' || user.tier==='ultimate' ) { %>
                    <button id="aiGenerateBtn"
                        class="w-full bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-500 hover:to-blue-500 text-white font-bold py-3 rounded-lg shadow-[0_0_20px_rgba(147,51,234,0.3)] transition-all transform hover:-translate-y-0.5 relative overflow-hidden">
                        <div
                            class="absolute inset-0 bg-white/20 translate-y-full hover:translate-y-0 transition-transform">
                        </div>
                        <span class="relative z-10"><i class="fas fa-bolt mr-2 text-yellow-300"></i> Generate Premium
                            Signal</span>
                    </button>
                    <% } else { %>
                        <div class="bg-purple-900/30 border border-purple-500/30 rounded-lg p-4 text-center">
                            <h4 class="text-purple-300 font-bold mb-2 flex justify-center items-center"><i
                                    class="fas fa-lock mr-2"></i> Premium Feature</h4>
                            <p class="text-xs text-gray-400 mb-3">Upgrade to Pro to access advanced AI trading signals.
                            </p>
                            <a href="/profile"
                                class="inline-block bg-purple-600 hover:bg-purple-500 text-white text-xs font-bold py-2 px-4 rounded transition-colors">Upgrade
                                Now</a>
                        </div>
                        <% } %>
            </div>

            <!-- Stats/Performance Summary -->
            <% if (user.tier==='pro' || user.tier==='ultimate' ) { %>
                <div class="glass-panel border border-white/10 rounded-2xl p-6">
                    <h3 class="text-lg font-bold text-white mb-4"><i
                            class="fas fa-chart-line text-emerald-400 mr-2"></i> Your Performance</h3>
                    <div class="space-y-3">
                        <div class="flex justify-between items-center border-b border-white/5 pb-2">
                            <span class="text-gray-400 text-sm">Win Rate</span>
                            <span class="text-emerald-400 font-bold" id="aiWinRate">--%</span>
                        </div>
                        <div class="flex justify-between items-center border-b border-white/5 pb-2">
                            <span class="text-gray-400 text-sm">Total Trades</span>
                            <span class="text-white font-bold" id="aiTotalTrades">0</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-400 text-sm">Est PnL</span>
                            <span class="text-blue-400 font-bold" id="aiTotalPnl">$0.00</span>
                        </div>
                    </div>
                </div>
                <% } %>
        </div>

        <!-- Right Column: Chart & History -->
        <div class="lg:col-span-2 flex flex-col gap-6">

            <!-- TradingView Chart Container -->
            <div class="glass-panel border border-white/10 rounded-2xl p-1 overflow-hidden h-[400px]">
                <!-- Wrapped in a div with pointer-events block to allow interaction if needed, or overlay for lock -->
                <% if (user.tier==='pro' || user.tier==='ultimate' ) { %>
                    <div id="aiTradingViewContainer" class="w-full h-full rounded-xl overflow-hidden">
                        <!-- TV Widget injected here -->
                    </div>
                    <% } else { %>
                        <div
                            class="w-full h-full flex flex-col items-center justify-center bg-gray-900/80 rounded-xl relative overflow-hidden group">
                            <div
                                class="absolute inset-0 bg-[url('https://s3.tradingview.com/tv.js')] opacity-10 blur-sm bg-cover bg-center">
                            </div>
                            <div
                                class="absolute inset-0 flex flex-col items-center justify-center z-10 p-6 text-center">
                                <i
                                    class="fas fa-lock text-4xl text-gray-500 mb-4 group-hover:text-purple-400 transition-colors"></i>
                                <h3 class="text-xl font-bold text-white mb-2">Live Market Data Locked</h3>
                                <p class="text-sm text-gray-400 max-w-md">Pro and Ultimate subscribers get access to
                                    real-time interactive charts integrated directly with the AI signal engine.</p>
                            </div>
                        </div>
                        <% } %>
            </div>

            <!-- Recent Trades History -->
            <% if (user.tier==='pro' || user.tier==='ultimate' ) { %>
                <div class="glass-panel border border-white/10 rounded-2xl p-6 flex-1 min-h-[250px] flex flex-col">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="text-lg font-bold text-white"><i class="fas fa-history text-blue-400 mr-2"></i>
                            Signal History</h3>
                        <button id="aiClearHistoryBtn"
                            class="text-xs text-gray-500 hover:text-red-400 transition-colors"><i
                                class="fas fa-trash-alt mr-1"></i>Clear</button>
                    </div>

                    <div class="flex-1 overflow-y-auto custom-scrollbar pr-2" id="aiHistoryContainer">
                        <!-- Populated by JS -->
                        <div class="flex items-center justify-center h-full text-sm text-gray-500 italic">No signals
                            generated yet this session.</div>
                    </div>
                </div>
                <% } %>

        </div>
    </div>
</div>

<!-- Dependency for TradingView (MUST be loaded before any widget initialization) -->
<% if (user.tier==='pro' || user.tier==='ultimate' ) { %>
    <script type="text/javascript" src="https://s3.tradingview.com/tv.js"></script>
    <% } %>

        <style>
            /* Utilities for AI Trading Bot */
            .ai-select-btn {
                background: rgba(255, 255, 255, 0.05);
                border: 1px solid rgba(255, 255, 255, 0.1);
                color: #9ca3af;
                border-radius: 0.5rem;
                padding: 0.5rem;
                transition: all 0.2s;
                font-weight: 500;
            }

            .ai-select-btn:hover {
                background: rgba(255, 255, 255, 0.1);
                color: white;
            }

            .ai-select-btn.active {
                background: rgba(147, 51, 234, 0.2);
                border-color: rgba(147, 51, 234, 0.5);
                color: #c084fc;
                box-shadow: 0 0 10px rgba(147, 51, 234, 0.1);
            }

            .signal-blip {
                animation: ping-slow 2s cubic-bezier(0, 0, 0.2, 1) infinite;
            }

            @keyframes ping-slow {

                75%,
                100% {
                    transform: scale(1.5);
                    opacity: 0;
                }
            }

            .profit-flash {
                animation: flash-green 1s ease-out;
            }

            .loss-flash {
                animation: flash-red 1s ease-out;
            }

            @keyframes flash-green {
                0% {
                    background-color: rgba(16, 185, 129, 0.4);
                    box-shadow: inset 0 0 20px rgba(16, 185, 129, 0.5);
                }

                100% {
                    background-color: transparent;
                }
            }

            @keyframes flash-red {
                0% {
                    background-color: rgba(239, 68, 68, 0.4);
                    box-shadow: inset 0 0 20px rgba(239, 68, 68, 0.5);
                }

                100% {
                    background-color: transparent;
                }
            }
        </style>

        <script>
            // Pass user tier to client script safely
            window.USER_TIER = '<%= user.tier %>';
        </script>
        <script src="/js/tradingBot.js"></script>