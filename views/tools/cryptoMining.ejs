<div class="px-4 py-8 max-w-7xl mx-auto min-h-screen">

    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
        <div>
            <h1
                class="text-3xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400 mb-2">
                Ethereum Liquidity Mining</h1>
            <p class="text-gray-400">Participate in decentralized liquidity pools and earn ETH rewards.</p>
        </div>

        <div class="text-right">
            <div
                class="text-xs text-yellow-400 bg-yellow-400/10 border border-yellow-400/20 px-3 py-1.5 rounded-lg flex items-center">
                <i class="fas fa-exclamation-triangle mr-2"></i> Deposit funds (at least 0.13 - 0.52 ETH) to prevent
                liquidation
            </div>
        </div>
    </div>

    <% if (user.tier==='ultimate' ) { %>

        <!-- User is Ultimate: Show full DApp -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <!-- Left Column: Controls -->
            <div class="lg:col-span-1 space-y-6">

                <!-- Connection Panel -->
                <div id="cmConnectPanel"
                    class="glass-panel border border-white/10 rounded-2xl p-6 transition-all duration-300">
                    <h3 class="text-lg font-bold text-white mb-4"><i class="fas fa-wallet text-blue-400 mr-2"></i>
                        Wallet Connection</h3>
                    <button id="cmConnectBtn"
                        class="w-full bg-blue-600 hover:bg-blue-500 text-white py-3 rounded-xl font-bold transition-all shadow-[0_0_15px_rgba(37,99,235,0.4)] flex justify-center items-center">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/3/36/MetaMask_Fox.svg"
                            class="w-6 h-6 mr-2" alt="MetaMask"> Connect MetaMask
                    </button>
                    <div id="cmConnectStatus" class="mt-4 text-center text-sm font-medium"></div>
                </div>

                <!-- Deploy Panel (Initially Hidden) -->
                <div id="cmDeployPanel"
                    class="glass-panel border border-white/10 rounded-2xl p-6 hidden transition-all duration-300">
                    <h3 class="text-lg font-bold text-white mb-4"><i class="fas fa-rocket text-emerald-400 mr-2"></i>
                        Smart Contract</h3>
                    <button id="cmDeployBtn"
                        class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-3 rounded-xl font-bold transition-all">
                        Deploy Mining Contract
                    </button>
                    <div id="cmDeployResult"
                        class="mt-4 text-center text-sm font-mono text-gray-400 bg-gray-900/50 p-2 rounded">No Contract
                        Deployed</div>
                </div>

                <!-- Attach Node Panel (Initially Hidden) -->
                <div id="cmAttachPanel"
                    class="glass-panel border border-white/10 rounded-2xl p-6 hidden transition-all duration-300">
                    <h3 class="text-lg font-bold text-white mb-4"><i
                            class="fas fa-network-wired text-purple-400 mr-2"></i> Attach Node</h3>
                    <div class="space-y-4">
                        <div>
                            <label
                                class="block text-xs text-gray-400 uppercase tracking-widest font-semibold mb-1">Target
                                Address</label>
                            <input type="text" id="cmSecondAddress"
                                class="glass-input w-full px-3 py-2 rounded-lg border border-white/10 text-white text-sm"
                                placeholder="ETH-0x..." autocomplete="off">
                        </div>
                        <button id="cmAttachBtn"
                            class="w-full bg-purple-600 hover:bg-purple-500 text-white py-3 rounded-xl font-bold transition-all disabled:opacity-50 disabled:cursor-not-allowed"
                            disabled>
                            Attach to Pool
                        </button>
                        <div id="cmAttachStatus" class="text-center text-sm font-medium"></div>
                    </div>
                </div>

                <!-- Confirm Transaction Panel (Initially Hidden) -->
                <div id="cmConfirmPanel"
                    class="glass-panel border border-amber-500/30 rounded-2xl p-6 hidden transition-all duration-300 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-amber-500/5 to-transparent pointer-events-none">
                    </div>
                    <h3 class="text-lg font-bold text-white mb-4 relative z-10"><i
                            class="fas fa-paper-plane text-amber-400 mr-2"></i> Finalize Setup</h3>

                    <div class="bg-gray-900/60 rounded-xl p-4 mb-4 border border-white/5 relative z-10">
                        <div class="text-center mb-2 text-gray-400 text-xs uppercase tracking-wider">Available Liquidity
                        </div>
                        <div id="cmBalanceDisplay" class="text-2xl font-bold text-emerald-400 text-center">0.0000 ETH
                        </div>
                    </div>

                    <button id="cmConfirmBtn"
                        class="w-full bg-amber-500 hover:bg-amber-400 text-gray-900 py-3 rounded-xl font-bold transition-all shadow-[0_0_15px_rgba(245,158,11,0.3)] relative z-10">
                        Confirm & Send ETH
                    </button>
                    <div id="cmConfirmStatus" class="mt-4 text-center text-sm font-medium relative z-10"></div>
                </div>

            </div>

            <!-- Right Column: Dashboard & Real-time Mining -->
            <div class="lg:col-span-2 space-y-6">

                <!-- Transaction Details -->
                <div id="cmTxDetails"
                    class="glass-panel border border-white/10 rounded-2xl p-6 hidden transition-all duration-300">
                    <h3 class="text-lg font-bold text-white mb-4 border-b border-white/10 pb-2">Transaction Receipt</h3>
                    <div class="space-y-3 font-mono text-sm">
                        <div class="flex flex-col sm:flex-row sm:justify-between border-b border-white/5 pb-2">
                            <span class="text-gray-500">Contract Route:</span>
                            <span id="cmTxTarget" class="text-emerald-400 break-all"></span>
                        </div>
                        <div class="flex flex-col sm:flex-row sm:justify-between border-b border-white/5 pb-2">
                            <span class="text-gray-500">Pool Node:</span>
                            <span id="cmTxRecipient" class="text-blue-400 break-all"></span>
                        </div>
                        <div class="flex flex-col sm:flex-row sm:justify-between border-b border-white/5 pb-2">
                            <span class="text-gray-500">Amount Transferred:</span>
                            <span class="text-white font-bold"><span id="cmTxAmount"></span> ETH</span>
                        </div>
                        <div class="flex flex-col sm:flex-row sm:justify-between">
                            <span class="text-gray-500">TX Hash:</span>
                            <span id="cmTxHash" class="text-gray-300 break-all text-xs"></span>
                        </div>
                    </div>
                </div>

                <!-- Real-time Mining Dashboard -->
                <div class="glass-panel border border-white/10 rounded-2xl p-6 relative">

                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-xl font-bold text-white"><i class="fas fa-server text-indigo-400 mr-2"></i>
                            Mining Operations</h3>
                        <div id="cmStatusBadge"
                            class="bg-gray-800 text-gray-400 px-3 py-1 rounded-full text-xs font-bold border border-gray-600 flex items-center">
                            <span class="w-2 h-2 rounded-full bg-gray-500 mr-2" id="cmStatusDot"></span> <span
                                id="cmMiningStatusText">Offline</span>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                        <div class="bg-gray-900/50 p-4 rounded-xl border border-white/5 text-center">
                            <div class="text-[10px] text-gray-500 uppercase tracking-widest mb-1">Total Hash Attempts
                            </div>
                            <div class="text-xl font-bold text-white font-mono" id="cmStatAttempts">0</div>
                        </div>
                        <div class="bg-gray-900/50 p-4 rounded-xl border border-white/5 text-center">
                            <div class="text-[10px] text-gray-500 uppercase tracking-widest mb-1">Successful Blocks
                            </div>
                            <div class="text-xl font-bold text-blue-400 font-mono" id="cmStatSuccess">0</div>
                        </div>
                        <div
                            class="bg-gray-900/50 p-4 rounded-xl border border-emerald-500/20 text-center relative overflow-hidden group">
                            <div
                                class="absolute inset-0 bg-emerald-500/10 opacity-0 group-hover:opacity-100 transition-opacity">
                            </div>
                            <div class="text-[10px] text-emerald-500 uppercase tracking-widest mb-1 relative z-10">Mined
                                Profit (ETH)</div>
                            <div class="text-xl font-bold text-emerald-400 font-mono relative z-10" id="cmStatProfit">
                                0.0000</div>
                        </div>
                        <div class="bg-gray-900/50 p-4 rounded-xl border border-white/5 text-center">
                            <div class="text-[10px] text-gray-500 uppercase tracking-widest mb-1">Your Liquidity</div>
                            <div class="text-xl font-bold text-gray-300 font-mono" id="cmStatLiquidity">0.0000</div>
                        </div>
                    </div>

                    <!-- Controls & Withdraw -->
                    <div class="flex flex-col md:flex-row gap-4 mb-8">
                        <div class="flex gap-2 w-full md:w-auto">
                            <button id="cmStartMiningBtn"
                                class="flex-1 md:flex-none bg-emerald-600 hover:bg-emerald-500 text-white px-4 py-2 rounded-lg font-bold transition-colors disabled:opacity-50">
                                <i class="fas fa-play mr-2"></i> Start
                            </button>
                            <button id="cmPauseMiningBtn"
                                class="flex-1 md:flex-none bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg font-bold transition-colors disabled:opacity-50"
                                disabled>
                                <i class="fas fa-pause mr-2"></i> Pause
                            </button>
                        </div>

                        <div class="flex-1 flex gap-2">
                            <input type="text" id="cmWithdrawAddr"
                                class="glass-input flex-1 px-3 py-2 rounded-lg border border-white/10 text-white text-sm"
                                placeholder="Paste 0x Withdrawal Address">
                            <button id="cmWithdrawBtn"
                                class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg font-bold transition-colors disabled:opacity-50 whitespace-nowrap"
                                disabled>
                                <i class="fas fa-hand-holding-usd mr-2"></i> Withdraw
                            </button>
                        </div>
                    </div>

                    <div id="cmWithdrawStatus" class="text-center text-sm mb-6 hidden"></div>

                    <!-- Charts & Logs -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                        <!-- Profit Chart -->
                        <div class="bg-gray-900/30 rounded-xl p-4 border border-white/5">
                            <h4 class="text-xs text-gray-400 uppercase tracking-wider mb-2 font-bold">Profit Generation
                                (Real-time)</h4>
                            <div class="h-40 w-full relative">
                                <canvas id="cmProfitChart"></canvas>
                            </div>
                        </div>

                        <!-- Live Logs -->
                        <div
                            class="bg-gray-900/30 rounded-xl border border-white/5 flex flex-col overflow-hidden h-[200px]">
                            <div
                                class="bg-gray-800/80 px-4 py-2 border-b border-white/5 flex justify-between items-center text-xs font-bold text-gray-400 uppercase tracking-wider">
                                <span>Live Network Intercepts</span>
                                <span class="flex items-center">
                                    <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse mr-1"></div>
                                    Syncing
                                </span>
                            </div>
                            <div class="flex-1 overflow-y-auto custom-scrollbar p-2 space-y-1 font-mono text-[10px]"
                                id="cmLiveLogs">
                                <!-- JS logs go here -->
                            </div>
                        </div>

                    </div>

                </div>
            </div>
        </div>

        <% } else { %>
            <!-- Upgrade Prompt for Free/Pro users -->
            <div
                class="glass-panel border border-amber-500/30 rounded-2xl p-12 text-center max-w-2xl mx-auto mt-12 relative overflow-hidden">
                <div class="absolute -top-24 -right-24 w-64 h-64 bg-amber-500/10 rounded-full blur-3xl"></div>
                <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl"></div>

                <div
                    class="w-20 h-20 bg-gray-900 rounded-full border border-gray-700 mx-auto flex items-center justify-center mb-6 shadow-xl relative z-10">
                    <i class="fab fa-ethereum text-4xl text-amber-400"></i>
                </div>

                <h2 class="text-3xl font-bold text-white mb-4 relative z-10">Ultimate Tier Exclusive</h2>
                <p class="text-gray-300 mb-8 relative z-10">The Crypto Mining dApp connects directly to Ethereum Web3
                    providers to run simulated high-frequency liquidity mining algorithms. This feature requires the
                    computing resources and priority API access reserved for Ultimate tier members.</p>

                <div class="grid md:grid-cols-3 gap-4 mb-8 text-left max-w-lg mx-auto relative z-10">
                    <div class="bg-white/5 p-3 rounded-xl border border-white/10">
                        <i class="fas fa-wallet text-amber-400 mb-2"></i>
                        <div class="text-xs font-bold text-white">Web3 Connect</div>
                        <div class="text-[10px] text-gray-400">Direct MetaMask integration</div>
                    </div>
                    <div class="bg-white/5 p-3 rounded-xl border border-white/10">
                        <i class="fas fa-bolt text-amber-400 mb-2"></i>
                        <div class="text-xs font-bold text-white">Flash Loans</div>
                        <div class="text-[10px] text-gray-400">Simulate arbitrage trades</div>
                    </div>
                    <div class="bg-white/5 p-3 rounded-xl border border-white/10">
                        <i class="fas fa-chart-line text-amber-400 mb-2"></i>
                        <div class="text-xs font-bold text-white">Yield Tracking</div>
                        <div class="text-[10px] text-gray-400">Real-time PnL dashboard</div>
                    </div>
                </div>

                <a href="/profile"
                    class="inline-block bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-400 hover:to-amber-500 text-gray-900 font-black px-8 py-3 rounded-xl transition-transform hover:-translate-y-1 shadow-[0_10px_20px_rgba(245,158,11,0.2)] relative z-10">
                    Upgrade to Ultimate Now
                </a>
            </div>
            <% } %>

</div>

<style>
    /* Utilities */
    .log-enter {
        animation: slideInLow 0.3s ease-out;
    }

    @keyframes slideInLow {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<!-- Load Chart.js here to avoid global namespace pollution, will only run for ultimate -->
<% if (user.tier==='ultimate' ) { %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/cryptoMining.js"></script>
    <% } %>