                        <i class="fas fa-edit"></i>
                    </div>
                    SEO Title Optimizer
                </h2>
                <div class="grid md:grid-cols-2 gap-8">
                    <div>
                        <div class="mb-4">
                            <label class="block text-xs text-gray-400 uppercase tracking-widest font-semibold mb-2">Raw
