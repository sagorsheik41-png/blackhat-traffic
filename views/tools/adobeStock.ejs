        </div>

        <!-- Right Column: Tab Content Container -->
        <div class="lg:col-span-9 glass-panel border border-white/10 rounded-2xl p-6 min-h-[600px] relative">

            <!-- Tab 1: Creative Brief -->
            <div id="asTabBrief" class="as-tab-content block">
                <h2 class="text-2xl font-bold text-white mb-6 flex items-center">
                    <div
                        class="w-10 h-10 rounded-lg bg-yellow-500/20 text-yellow-500 flex items-center justify-center mr-3 shadow-[0_0_15px_rgba(234,179,8,0.2)]">
                        <i class="fas fa-rocket"></i>
                    </div>
                    AI Creative Brief Generator
                </h2>
                <div class="grid md:grid-cols-2 gap-6 mb-8">
                    <div>
                        <label
                            class="block text-xs text-gray-400 uppercase tracking-widest font-semibold mb-2">Category</label>
                        <select id="asBriefCat"
                            class="glass-input w-full px-4 py-3 rounded-xl border border-white/10 text-white bg-gray-900/50">
                            <option value="">Select a category...</option>
                            <option value="business">Business & Corporate</option>
                            <option value="technology">Technology & AI</option>
                            <option value="lifestyle">Lifestyle & Wellness</option>
                            <option value="abstract">Abstract Backgrounds</option>
                            <option value="holiday">Holidays & Seasons</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs text-gray-400 uppercase tracking-widest font-semibold mb-2">Visual
                            Style</label>
                        <select id="asBriefStyle"
                            class="glass-input w-full px-4 py-3 rounded-xl border border-white/10 text-white bg-gray-900/50">
                            <option value="">Select style...</option>
                            <option value="3d">3D Rendered</option>
                            <option value="flat">Flat Illustration</option>
                            <option value="photo">Cinematic Photography</option>
                            <option value="minimal">Minimalist</option>
                        </select>
                    </div>
                </div>
                <button id="asGenBriefBtn"
                    class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl shadow-[0_0_20px_rgba(37,99,235,0.4)] transition-all mb-8">
                    Generate Creative Brief
                </button>
                <div id="asBriefOutput" class="hidden grid md:grid-cols-2 gap-6">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-semibold text-gray-400 mb-2">Title Suggestions</label>
                            <textarea id="asBriefTitles"
                                class="glass-input w-full h-24 p-3 rounded-lg border border-white/10 text-white text-sm bg-black/30"
                                readonly></textarea>
                            <button
                                class="as-copy-btn mt-2 text-xs bg-gray-800 hover:bg-gray-700 px-3 py-1 rounded border border-white/10 transition-colors"
                                data-copy="asBriefTitles">Copy</button>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-400 mb-2">Description / Prompt
                                Ideas</label>
                            <textarea id="asBriefDesc"
                                class="glass-input w-full h-32 p-3 rounded-lg border border-white/10 text-white text-sm bg-black/30"
                                readonly></textarea>
                            <button
                                class="as-copy-btn mt-2 text-xs bg-gray-800 hover:bg-gray-700 px-3 py-1 rounded border border-white/10 transition-colors"
                                data-copy="asBriefDesc">Copy</button>
                        </div>
                    </div>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-semibold text-gray-400 mb-2">Target Keywords</label>
                            <textarea id="asBriefKeywords"
                                class="glass-input w-full h-24 p-3 rounded-lg border border-white/10 text-white text-sm bg-black/30"
                                readonly></textarea>
                            <button
                                class="as-copy-btn mt-2 text-xs bg-gray-800 hover:bg-gray-700 px-3 py-1 rounded border border-white/10 transition-colors"
                                data-copy="asBriefKeywords">Copy</button>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-400 mb-2">Trending Variations</label>
                            <textarea id="asBriefTips"
                                class="glass-input w-full h-32 p-3 rounded-lg border border-white/10 text-white text-sm bg-black/30"
                                readonly></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab 2: Keyword Research -->
            <div id="asTabKeywords" class="as-tab-content hidden">
                <h2 class="text-2xl font-bold text-white mb-6 flex items-center">
