                    <button class="as-tab-btn" data-target="asTabKeywords">
                        <i class="fas fa-search w-6"></i> Keyword Research
                    </button>
                    <button class="as-tab-btn" data-target="asTabTitle">
                        <i class="fas fa-edit w-6"></i> Title Optimizer
