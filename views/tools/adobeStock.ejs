                        </div>
                        <div class="mb-6 space-y-3 bg-gray-900/30 p-4 rounded-xl border border-white/5">
                            <label class="flex items-center text-sm text-gray-300">
                                <input type="checkbox" id="asTitleOptSeo" checked
                                    class="form-checkbox bg-gray-800 border-gray-600 text-indigo-500 rounded mr-3">
                                Inject High-Volume SEO Terms
                            </label>
                            <label class="flex items-center text-sm text-gray-300">
                                <input type="checkbox" id="asTitleOptEmotional"
                                    class="form-checkbox bg-gray-800 border-gray-600 text-indigo-500 rounded mr-3"> Add
                                Emotional Hooks (e.g. Beautiful, Stunning)
                            </label>
                        </div>
                        <button id="asGenTitleBtn"
                            class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 rounded-xl shadow-[0_0_20px_rgba(99,102,241,0.4)] transition-all">
                            Optimize Title
                        </button>
                    </div>
                    <div class="flex flex-col">
                        <label class="block text-sm font-semibold text-gray-400 mb-2">Optimized Selling Titles</label>
                        <div id="asTitleOutput" class="flex-1 space-y-3 overflow-y-auto">
                            <div class="text-gray-500 text-sm italic text-center mt-8">Optimized variations will appear
                                here</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab 4: Color Palette -->
            <div id="asTabPalette" class="as-tab-content hidden">
                <h2 class="text-2xl font-bold text-white mb-6 flex items-center">
                    <div
                        class="w-10 h-10 rounded-lg bg-fuchsia-500/20 text-fuchsia-400 flex items-center justify-center mr-3 shadow-[0_0_15px_rgba(217,70,239,0.2)]">
                        <i class="fas fa-paint-brush"></i>
                    </div>
                    Vector Color Palette Generator
                </h2>
                <div class="max-w-3xl mx-auto">
                    <div class="flex gap-4 mb-8">
                        <div class="flex-1">
                            <label
                                class="block text-xs text-gray-400 uppercase tracking-widest font-semibold mb-2">Theme
                                Profile</label>
                            <select id="asPaletteTheme"
                                class="glass-input w-full px-4 py-3 rounded-xl border border-white/10 text-white bg-gray-900/50">
                                <option value="modern">Modern & Clean</option>
                                <option value="cyberpunk">Cyberpunk / Synthwave</option>
                                <option value="pastel">Soft Pastels</option>
                                <option value="corporate">Corporate Blue/Gray</option>
                                <option value="sunset">Warm Sunset</option>
                            </select>
                        </div>
                        <div class="w-32">
                            <label class="block text-xs text-gray-400 uppercase tracking-widest font-semibold mb-2">Base
                                Seed</label>
                            <input type="color" id="asPaletteBase" value="#6366f1"
                                class="w-full h-[50px] p-1 bg-gray-900/50 border border-white/10 rounded-xl cursor-pointer">
                        </div>
                    </div>
                    <button id="asGenPaletteBtn"
                        class="w-full bg-fuchsia-600 hover:bg-fuchsia-500 text-white font-bold py-3 rounded-xl shadow-[0_0_20px_rgba(217,70,239,0.4)] transition-all mb-10">
                        Generate Hex Palette
                    </button>

                    <div id="asPaletteContainer" class="hidden">
                        <div class="relative w-full h-32 rounded-2xl overflow-hidden flex mb-4 shadow-2xl"
                            id="asPaletteStrip">
                            <!-- Visual strips appended here -->
                        </div>
                        <div class="grid grid-cols-5 gap-2 text-center" id="asPaletteHexes">
                            <!-- Hex codes appended here -->
                        </div>
                    </div>

                </div>
            </div>

            <!-- Tab 5: Batch Metadata ZIP Tool -->
            <div id="asTabBatch" class="as-tab-content hidden">
                <h2 class="text-2xl font-bold text-white mb-2 flex items-center">
                    <div
                        class="w-10 h-10 rounded-lg bg-teal-500/20 text-teal-400 flex items-center justify-center mr-3 shadow-[0_0_15px_rgba(20,181,158,0.2)]">
                        <i class="fas fa-layer-group"></i>
                    </div>
                    Smart Bulk Download & File Packager
                </h2>
                <p class="text-gray-400 text-sm mb-6 max-w-2xl">Drop image or vector files here. We will append SEO
                    optimized names based on your input and package them into a single ZIP archive ready for Adobe Stock
                    ingestion.</p>

                <div class="grid md:grid-cols-5 gap-6">
                    <div class="md:col-span-2 space-y-4">
                        <div>
                            <label
                                class="block text-xs text-gray-400 uppercase tracking-widest font-semibold mb-2">Global
                                Prefix/Description</label>
                            <input type="text" id="asBatchPrefix" placeholder="e.g. 3d abstract background"
                                class="glass-input w-full px-3 py-2 rounded-lg border border-white/10 text-white bg-gray-900/50">
                        </div>
                        <div class="bg-gray-900/40 p-4 rounded-xl border border-white/5 text-sm space-y-3">
                            <div class="flex items-center justify-between text-gray-300">
                                <span>Files Selected:</span>
                                <span id="asBatchCount" class="font-bold text-white">0</span>
                            </div>
                            <div class="flex items-center justify-between text-gray-300">
                                <span>Detected Types:</span>
                                <span id="asBatchTypes" class="font-bold text-blue-400">-</span>
                            </div>
                            <button id="asBatchClearBtn"
                                class="w-full text-xs text-red-400 hover:text-red-300 underline mt-2 block text-center disabled:opacity-50">Clear
                                Queue</button>
                        </div>
                        <button id="asBatchZipBtn"
                            class="w-full bg-teal-600 hover:bg-teal-500 text-white font-bold py-3 rounded-xl shadow-[0_0_20px_rgba(20,181,158,0.4)] transition-all disabled:opacity-50 disabled:cursor-not-allowed"
                            disabled>
                            Generate ZIP Archive
                        </button>
                    </div>

                    <div class="md:col-span-3">
                        <div id="asDropZone"
                            class="border-2 border-dashed border-gray-600 hover:border-teal-500 bg-gray-900/30 rounded-2xl p-8 text-center transition-colors cursor-pointer min-h-[250px] flex flex-col items-center justify-center">
                            <i class="fas fa-cloud-upload-alt text-5xl text-gray-500 mb-4 pointer-events-none"></i>
                            <h3 class="text-lg font-bold text-gray-300 pointer-events-none">Drag & Drop Files Here</h3>
                            <p class="text-sm text-gray-500 mt-2 pointer-events-none">Supported: JPG, PNG, SVG, EPS, AI
                            </p>
                            <input type="file" id="asBatchFileInput" multiple class="hidden">
                        </div>

                        <div id="asBatchPreview" class="mt-4 space-y-2 max-h-[200px] overflow-y-auto">
                            <!-- File previews injected here -->
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    /* Additional component scoping for Adobe Stock */
    .as-tab-btn {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        background: transparent;
        border: 1px solid transparent;
        color: #9ca3af;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s ease;
        text-align: left;
    }

    .as-tab-btn:hover {
        background: rgba(255, 255, 255, 0.05);
        color: #e5e7eb;
    }

    .as-tab-btn.active {
        background: rgba(59, 130, 246, 0.1);
        border-color: rgba(59, 130, 246, 0.3);
        color: #60a5fa;
    }

    .as-kw-badge {
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.3);
        color: #34d399;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.2s;
    }

    .as-kw-badge:hover {
