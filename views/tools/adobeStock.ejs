                        class="w-10 h-10 rounded-lg bg-emerald-500/20 text-emerald-500 flex items-center justify-center mr-3 shadow-[0_0_15px_rgba(16,185,129,0.2)]">
                        <i class="fas fa-search"></i>
                    </div>
                    Advanced Keyword Research
                </h2>
                <div class="grid md:grid-cols-2 gap-8">
                    <div>
                        <div class="mb-4">
                            <label class="block text-xs text-gray-400 uppercase tracking-widest font-semibold mb-2">Base
                                Subject/Keyword</label>
                            <input type="text" id="asKwBase" placeholder="e.g. happy golden retriever"
                                class="glass-input w-full px-4 py-3 rounded-xl border border-white/10 text-white bg-gray-900/50">
                        </div>
                        <div class="mb-6">
                            <label
                                class="block text-xs text-gray-400 uppercase tracking-widest font-semibold mb-2">Target
                                Audience / Niche</label>
                            <select id="asKwAudience"
                                class="glass-input w-full px-4 py-3 rounded-xl border border-white/10 text-white bg-gray-900/50">
                                <option value="general">General Commercial</option>
                                <option value="business">Corporate/B2B</option>
                                <option value="creative">Creative/Design</option>
                                <option value="social">Social Media</option>
                            </select>
                        </div>
                        <button id="asGenKwBtn"
                            class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-3 rounded-xl shadow-[0_0_20px_rgba(16,185,129,0.4)] transition-all">
                            Generate SEO Keywords
                        </button>
                    </div>
                    <div class="flex flex-col">
                        <label class="block text-sm font-semibold text-gray-400 mb-2">Extracted Keywords (30-50
                            recommended)</label>
                        <div id="asKwOutput"
                            class="flex-1 bg-black/30 border border-white/10 rounded-xl p-4 flex flex-wrap content-start gap-2 overflow-y-auto min-h-[200px]">
                            <p class="text-gray-500 text-sm italic w-full text-center mt-8">Keywords will populate
                                here...</p>
                        </div>
                        <div class="mt-4 flex gap-2">
                            <button id="asKwCopyBtn"
                                class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded-lg text-sm border border-white/10 flex-1 transition-colors"><i
                                    class="fas fa-copy mr-2"></i> Copy All Comma-Separated</button>
                            <button id="asKwClearBtn"
                                class="bg-red-900/30 hover:bg-red-900/50 text-red-400 px-4 py-2 rounded-lg text-sm border border-red-500/30 transition-colors"><i
                                    class="fas fa-trash"></i></button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab 3: Title Optimizer -->
            <div id="asTabTitle" class="as-tab-content hidden">
                <h2 class="text-2xl font-bold text-white mb-6 flex items-center">
