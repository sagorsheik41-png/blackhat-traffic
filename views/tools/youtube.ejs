<!-- YouTube Content Generator — Fully Migrated -->
<div class="max-w-5xl mx-auto space-y-8">

    <!-- Header -->
    <div class="glass-card p-6 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-red-600/20 to-orange-600/20"></div>
        <div class="relative z-10 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <div
                    class="w-14 h-14 rounded-2xl bg-gradient-to-br from-red-500 to-orange-600 flex items-center justify-center shadow-lg">
                    <i class="fab fa-youtube text-white text-2xl"></i>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-white">YouTube Content Generator</h2>
                    <p class="text-sm text-gray-400">One-click Video Creation for Mystery, Paranormal & Crime</p>
                </div>
            </div>
            <div class="flex gap-4 text-right">
                <div>
                    <div class="text-xs text-gray-400 mb-1"><i class="fas fa-chart-line text-green-400 mr-1"></i> SEO
                        Score</div>
                    <div class="text-xl font-bold text-white"><span id="seoScore">0</span><span
                            class="text-sm text-gray-500">/100</span></div>
                </div>
                <div>
                    <div class="text-xs text-gray-400 mb-1"><i class="fas fa-fire text-orange-400 mr-1"></i> Viral
                        Potential</div>
                    <div class="text-xl font-bold text-white"><span id="viralScore">0</span><span
                            class="text-sm text-gray-500">%</span></div>
                </div>
            </div>
        </div>
    </div>

    <!-- API Context (Hidden) -->
    <input type="hidden" id="geminiApiKey" value="<%= user.apiKeys?.gemini || '' %>">


    <div class="glass-card p-6">
        <!-- Category Selector -->
        <div class="flex flex-wrap gap-3 mb-8" id="videoSelector">
            <button
                class="cat-btn active px-4 py-2 rounded-xl text-sm font-bold border-2 border-red-500 bg-red-500/20 text-red-400 transition-all"
                data-video="mystery">Mystery & Crime</button>
            <button
                class="cat-btn px-4 py-2 rounded-xl text-sm font-bold border-2 border-white/10 bg-white/5 text-gray-400 hover:bg-white/10 transition-all"
                data-video="paranormal">Paranormal</button>
            <button
                class="cat-btn px-4 py-2 rounded-xl text-sm font-bold border-2 border-white/10 bg-white/5 text-gray-400 hover:bg-white/10 transition-all"
                data-video="conspiracy">Conspiracy</button>
            <button
                class="cat-btn px-4 py-2 rounded-xl text-sm font-bold border-2 border-white/10 bg-white/5 text-gray-400 hover:bg-white/10 transition-all"
                data-video="truecrime">True Crime</button>
            <button
                class="cat-btn px-4 py-2 rounded-xl text-sm font-bold border-2 border-white/10 bg-white/5 text-gray-400 hover:bg-white/10 transition-all"
                data-video="unsolved">Unsolved Cases</button>
        </div>

        <!-- Niche / Idea Input -->
        <div class="mb-8">
            <label class="block text-xs text-gray-400 uppercase tracking-widest font-semibold mb-2">Target Niche or
                Video Idea</label>
            <div class="relative">
                <input type="text" id="customIdeaInput"
                    placeholder="e.g. The mysterious disappearance of the Flannan Isles keepers..."
                    class="glass-input w-full px-5 py-4 rounded-2xl border border-white/10 text-white text-lg font-medium placeholder-gray-600 focus:border-red-500/50 focus:ring-1 focus:ring-red-500/50 transition-all">
            </div>
        </div>

        <!-- History / Concept Box -->
        <div class="bg-red-500/5 border border-red-500/20 rounded-2xl p-6 mb-8 relative">
            <div class="absolute top-0 left-0 w-1 h-full bg-red-500 rounded-l-2xl"></div>

            <div class="flex items-center justify-between mb-4">
                <h3 class="text-red-400 font-bold flex items-center gap-2"><i class="fas fa-lightbulb"></i> Video
                    Concept / Storyline</h3>
                <button onclick="copyContent('history')" class="text-gray-400 hover:text-white transition-colors"><i
                        class="fas fa-copy"></i></button>
            </div>

            <p id="historyContent" class="text-gray-300 text-lg leading-relaxed mb-6 font-medium">Loading concept...</p>

            <div class="flex flex-col sm:flex-row gap-4">
                <button id="generateHistoryBtn"
                    class="px-6 py-3 rounded-xl bg-white/10 hover:bg-white/20 text-white font-bold transition-all flex items-center justify-center gap-2">
                    <i class="fas fa-sync-alt"></i> New Concept
                </button>
                <button id="generateVideoBtn"
                    class="flex-1 px-6 py-3 rounded-xl bg-gradient-to-r from-red-600 to-orange-600 hover:from-red-500 hover:to-orange-500 text-white font-bold shadow-lg hover:shadow-red-500/30 transition-all flex items-center justify-center gap-2">
                    <i class="fas fa-play-circle"></i> Generate Complete Video Content
                </button>
            </div>
        </div>

        <!-- Progress Bar -->
        <div class="h-1.5 w-full bg-white/10 rounded-full mb-8 overflow-hidden">
            <div id="progressBar" class="h-full bg-red-500 w-0 transition-all duration-500"></div>
        </div>

        <!-- Work Area Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <!-- Title Section -->
            <div class="content-section bg-black/20 border border-white/5 rounded-2xl p-5 flex flex-col h-full">
                <div class="flex items-center justify-between mb-4">
                    <h4 class="font-bold text-gray-300 flex items-center gap-2"><i
                            class="fas fa-heading text-red-400"></i> Title</h4>
                    <div class="flex gap-2">
                        <button id="generateTitleBtn"
                            class="text-xs bg-red-500/20 hover:bg-red-500/40 text-red-400 px-3 py-1.5 rounded-lg transition-all"><i
                                class="fas fa-magic"></i></button>
                        <button onclick="copyContent('title')"
                            class="text-xs bg-white/10 hover:bg-white/20 text-white px-3 py-1.5 rounded-lg transition-all"><i
                                class="fas fa-copy"></i></button>
                    </div>
                </div>
                <div id="titleContent" class="text-white text-lg font-bold flex-1 mb-4 select-all">Title will appear
                    here...</div>
                <div class="flex items-center justify-between text-xs border-t border-white/10 pt-3">
                    <span class="text-gray-500"><span id="titleLength">0</span>/70 chars</span>
                    <span id="titleScore" class="font-bold text-gray-500">SEO: Pending</span>
                </div>
            </div>

            <!-- Description Section -->
            <div
                class="content-section bg-black/20 border border-white/5 rounded-2xl p-5 flex flex-col h-full lg:col-span-2">
                <div class="flex items-center justify-between mb-4">
                    <h4 class="font-bold text-gray-300 flex items-center gap-2"><i
                            class="fas fa-align-left text-red-400"></i> Description</h4>
                    <div class="flex gap-2">
                        <button id="generateDescBtn"
                            class="text-xs bg-red-500/20 hover:bg-red-500/40 text-red-400 px-3 py-1.5 rounded-lg transition-all"><i
                                class="fas fa-magic"></i></button>
                        <button onclick="copyContent('description')"
                            class="text-xs bg-white/10 hover:bg-white/20 text-white px-3 py-1.5 rounded-lg transition-all"><i
                                class="fas fa-copy"></i></button>
                    </div>
                </div>
                <div id="descContent"
                    class="text-gray-300 text-sm whitespace-pre-wrap flex-1 mb-4 select-all font-mono">Description will
                    appear here...</div>
                <div class="flex items-center justify-between text-xs border-t border-white/10 pt-3">
                    <span class="text-gray-500"><span id="descLength">0</span>/5000 chars</span>
                    <span id="descScore" class="font-bold text-gray-500">SEO: Pending</span>
                </div>
            </div>

            <!-- Keywords Section -->
            <div
                class="content-section bg-black/20 border border-white/5 rounded-2xl p-5 flex flex-col h-full lg:col-span-3">
                <div class="flex items-center justify-between mb-4">
                    <h4 class="font-bold text-gray-300 flex items-center gap-2"><i
                            class="fas fa-hashtag text-red-400"></i> Keywords & Tags</h4>
                    <div class="flex gap-2">
                        <button id="generateKeywordsBtn"
                            class="text-xs bg-red-500/20 hover:bg-red-500/40 text-red-400 px-3 py-1.5 rounded-lg transition-all"><i
                                class="fas fa-magic"></i></button>
                        <button onclick="copyContent('keywords')"
                            class="text-xs bg-white/10 hover:bg-white/20 text-white px-3 py-1.5 rounded-lg transition-all"><i
                                class="fas fa-copy"></i></button>
                    </div>
                </div>
                <div id="keywordsContent" class="text-red-300 text-sm flex-1 mb-4 select-all font-mono">Keywords will
                    appear here...</div>
                <div class="flex items-center justify-between text-xs border-t border-white/10 pt-3">
                    <span class="text-gray-500"><span id="keywordsCount">0</span> tags</span>
                    <span id="keywordsScore" class="font-bold text-gray-500">SEO: Pending</span>
                </div>
            </div>

            <!-- Thumbnail Idea -->
            <div
                class="content-section bg-gradient-to-br from-gray-900 to-black border border-white/5 rounded-2xl p-6 lg:col-span-3 text-center relative overflow-hidden">
                <div
                    class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')] opacity-20">
                </div>
                <h4 class="font-bold text-white mb-4 relative z-10 text-lg">Thumbnail Concept</h4>
                <div
                    class="w-full max-w-2xl mx-auto h-48 bg-gradient-to-r from-red-900/50 to-orange-900/50 border border-red-500/30 rounded-xl flex items-center justify-center mb-4 relative z-10 shadow-2xl">
                    <span class="text-red-400/50 font-black tracking-widest text-2xl uppercase">Preview Area</span>
                </div>
                <p id="thumbnailText" class="text-gray-400 text-sm relative z-10 max-w-2xl mx-auto">Generate a title to
                    see a thumbnail concept suggestion here.</p>
            </div>

        </div>
    </div>
</div>

<script src="/js/youtube.js"></script>
    </body>
</html>
