<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Submit Inquiry | BlackHat Traffic</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #020617 0%, #0f172a 100%);
            min-height: 100vh;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 20px;
        }

        .form-card {
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            padding: 40px;
            margin-top: 30px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
        }

        .header {
            text-align: center;
            margin-bottom: 40px;
        }

        .header h1 {
            color: #ffffff;
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 10px;
        }

        .header p {
            color: #94a3b8;
            font-size: 16px;
        }

        .form-group {
            margin-bottom: 24px;
        }

        label {
            display: block;
            color: #e2e8f0;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 14px;
        }

        input,
        textarea,
        select {
            width: 100%;
            padding: 14px 16px;
            background: rgba(255, 255, 255, 0.03) !important;
            border: 1.5px solid rgba(255, 255, 255, 0.08) !important;
            border-radius: 12px !important;
            color: white !important;
            font-size: 14px !important;
            transition: all 0.3s ease !important;
            outline: none !important;
        }

        input:focus,
        textarea:focus,
        select:focus {
            border-color: #6366f1 !important;
            background: rgba(255, 255, 255, 0.06) !important;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1) !important;
        }

        textarea {
            resize: vertical;
            min-height: 150px;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        select {
            cursor: pointer;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
        }

        @media (max-width: 768px) {
            .form-row {
                grid-template-columns: 1fr;
            }

            .form-card {
                padding: 24px;
            }

            .header h1 {
                font-size: 24px;
            }
        }

        .btn-submit {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: white;
            font-weight: 700;
            font-size: 15px;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(99, 102, 241, 0.3);
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 40px rgba(99, 102, 241, 0.4);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

        .success-msg {
            background: rgba(16, 185, 129, 0.15);
            color: #34d399;
            padding: 16px;
            border-radius: 12px;
            font-size: 14px;
            margin-bottom: 20px;
            border: 1px solid rgba(16, 185, 129, 0.3);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .error-msg {
            background: rgba(239, 68, 68, 0.15);
            color: #f87171;
            padding: 16px;
            border-radius: 12px;
            font-size: 14px;
            margin-bottom: 20px;
            border: 1px solid rgba(239, 68, 68, 0.3);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .char-count {
            font-size: 12px;
            color: #64748b;
            margin-top: 4px;
        }

        .help-text {
            font-size: 12px;
            color: #94a3b8;
            margin-top: 4px;
        }

        .back-link {
            color: #818cf8;
            text-decoration: none;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 30px;
            transition: color 0.3s ease;
        }

        .back-link:hover {
            color: #6366f1;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="form-card">
            <a href="<%= typeof dashboard !== 'undefined' ? '/dashboard' : '/' %>" class="back-link">
                <i class="fas fa-arrow-left"></i> Back
            </a>

            <div class="header">
                <h1><i class="fas fa-envelope" style="margin-right: 12px;"></i>Submit Your Inquiry</h1>
                <p>Have a question or concern? We'd love to hear from you</p>
            </div>

            <% if (success_msg && success_msg.length > 0) { %>
                <div class="success-msg">
                    <i class="fas fa-check-circle"></i>
                    <span><%= success_msg %></span>
                </div>
                <% } %>
                    <% if (error && error.length > 0) { %>
                        <div class="error-msg">
                            <i class="fas fa-exclamation-circle"></i>
                            <span><%= error %></span>
                        </div>
                        <% } %>

                            <form method="POST" action="/inquiry" id="inquiryForm">
                                <!-- Name and Email Row -->
                                <div class="form-row">
                                    <div class="form-group">
                                        <label for="name"><i class="fas fa-user" style="margin-right: 6px;"></i>Full
                                            Name <span style="color: #ef4444;">*</span></label>
                                        <input type="text" name="name" id="name" placeholder="John Doe" required
                                            maxlength="255">
                                    </div>
                                    <div class="form-group">
                                        <label for="email"><i class="fas fa-envelope"
                                                style="margin-right: 6px;"></i>Email
                                            Address <span style="color: #ef4444;">*</span></label>
                                        <input type="email" name="email" id="email" placeholder="you@example.com"
                                            required>
                                    </div>
                                </div>

                                <!-- Phone and Category Row -->
                                <div class="form-row">
                                    <div class="form-group">
                                        <label for="phone"><i class="fas fa-phone"
                                                style="margin-right: 6px;"></i>Phone Number</label>
                                        <input type="tel" name="phone" id="phone" placeholder="+1 (234) 567-8900">
                                        <div class="help-text"><i class="fas fa-info-circle" style="margin-right: 4px;"></i>Optional - helps us contact you faster</div>
                                    </div>
                                    <div class="form-group">
                                        <label for="category"><i class="fas fa-tag"
                                                style="margin-right: 6px;"></i>Category <span style="color: #ef4444;">*</span></label>
                                        <select name="category" id="category" required>
                                            <option value="general">General Inquiry</option>
                                            <option value="support">Technical Support</option>
                                            <option value="complaint">Complaint</option>
                                            <option value="suggestion">Suggestion</option>
                                            <option value="account">Account Issue</option>
                                            <option value="billing">Billing Question</option>
                                            <option value="other">Other</option>
                                        </select>
                                    </div>
                                </div>

                                <!-- Subject -->
                                <div class="form-group">
                                    <label for="subject"><i class="fas fa-heading"
                                            style="margin-right: 6px;"></i>Subject</label>
                                    <input type="text" name="subject" id="subject"
                                        placeholder="Brief description of your inquiry" maxlength="255">
                                    <div class="help-text">Optional - helps us understand your inquiry better</div>
                                </div>

                                <!-- Message -->
                                <div class="form-group">
                                    <label for="message"><i class="fas fa-comments"
                                            style="margin-right: 6px;"></i>Message <span style="color: #ef4444;">*</span></label>
                                    <textarea name="message" id="message" placeholder="Please provide details about your inquiry..." required minlength="10" maxlength="5000"></textarea>
                                    <div class="char-count">
                                        <span id="charCount">0</span> / 5000 characters
                                    </div>
                                </div>

                                <!-- Submit Button -->
                                <button type="submit" class="btn-submit">
                                    <i class="fas fa-paper-plane" style="margin-right: 8px;"></i> Submit Inquiry
                                </button>
                            </form>

                            <div style="text-align: center; margin-top: 30px; color: #64748b; font-size: 14px;">
                                <p><i class="fas fa-shield-alt" style="margin-right: 6px; color: #6366f1;"></i> Your
                                    information is secure and will not be shared</p>
                            </div>
        </div>
    </div>

    <script>
        // Character counter for message
        const messageInput = document.getElementById('message');
        const charCount = document.getElementById('charCount');

        messageInput.addEventListener('input', function () {
            charCount.textContent = this.value.length;
        });

        // Form submission handler
        document.getElementById('inquiryForm').addEventListener('submit', function (e) {
            const submitBtn = this.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin" style="margin-right: 8px;"></i> Submitting...';
        });
    </script>
</body>

</html>
