<style>
  .blog-hero { background:linear-gradient(135deg,#0f172a,#1e1b4b,#0f172a);border-radius:18px;padding:48px 32px;text-align:center;margin-bottom:40px; }
  .blog-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px; }
  .blog-card { background:rgba(30,41,59,0.85);border:1px solid rgba(255,255,255,0.07);border-radius:16px;overflow:hidden;transition:all 0.3s;display:flex;flex-direction:column; }
  .blog-card:hover { transform:translateY(-4px);box-shadow:0 20px 40px rgba(79,70,229,0.2);border-color:rgba(99,102,241,0.3); }
  .blog-card-img { width:100%;height:180px;object-fit:cover; }
  .blog-card-img-placeholder { width:100%;height:180px;background:linear-gradient(135deg,#1e1b4b,#1e3a5f);display:flex;align-items:center;justify-content:center; }
  .blog-card-body { padding:20px;flex:1;display:flex;flex-direction:column; }
  .blog-date { font-size:11px;color:#64748b;font-weight:600;letter-spacing:0.5px; }
  .blog-title { font-size:1rem;font-weight:800;color:#f1f5f9;margin:8px 0;line-height:1.4; display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden; }
  .blog-excerpt { font-size:13px;color:#94a3b8;line-height:1.6; display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;flex:1; }
  .read-more { display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:700;color:#818cf8;margin-top:14px;transition:color 0.2s; }
  .read-more:hover { color:#a5b4fc; }
  .pagination-btn { padding:8px 18px;border-radius:12px;font-size:13px;font-weight:700;transition:all 0.2s; }
</style>

<!-- Blog Hero -->
<div class="blog-hero">
  <div class="text-4xl mb-3">📰</div>
  <h1 class="text-3xl font-black text-white mb-2">Blog & Guides</h1>
  <p class="text-slate-400 max-w-xl mx-auto">Tips, reviews, and guides on movies, apps, games, software and more.</p>
</div>

<!-- Blog Grid -->
<% if (posts.length === 0) { %>
<div class="text-center py-20">
  <i class="fas fa-newspaper text-5xl text-gray-600 mb-4"></i>
  <p class="text-gray-400 text-lg">No blog posts yet. Check back soon!</p>
</div>
<% } else { %>
<div class="blog-grid mb-10">
  <% posts.forEach(post => { %>
  <a href="/blog/<%= post.slug %>" class="blog-card">
    <% if (post.featuredImage) { %>
      <img src="<%= post.featuredImage %>" alt="<%= post.title %>" class="blog-card-img" loading="lazy">
    <% } else { %>
      <div class="blog-card-img-placeholder">
        <i class="fas fa-feather-alt text-indigo-400 text-4xl opacity-30"></i>
      </div>
    <% } %>
    <div class="blog-card-body">
      <div class="blog-date">
        <i class="fas fa-clock mr-1"></i>
        <%= post.createdAt ? new Date(post.createdAt).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'}) : '' %>
        <% if (post.views > 0) { %> · <i class="fas fa-eye ml-1 mr-1"></i> <%= post.views.toLocaleString() %> views<% } %>
      </div>
      <h2 class="blog-title"><%= post.title %></h2>
      <p class="blog-excerpt"><%= post.excerpt || post.content?.replace(/<[^>]+>/g,'').substring(0,220) %></p>
      <span class="read-more">Read more <i class="fas fa-arrow-right"></i></span>
    </div>
  </a>
  <% }) %>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<div class="flex justify-center gap-2 mt-6 mb-10">
  <% if (currentPage > 1) { %>
  <a href="/blog?page=<%= currentPage - 1 %>" class="pagination-btn bg-white/5 text-gray-400 hover:bg-white/10">← Previous</a>
  <% } %>
  <% for (let p = 1; p <= totalPages; p++) { %>
  <a href="/blog?page=<%= p %>" class="pagination-btn <%= p === currentPage ? 'bg-indigo-600 text-white' : 'bg-white/5 text-gray-400 hover:bg-white/10' %>"><%= p %></a>
  <% } %>
  <% if (currentPage < totalPages) { %>
  <a href="/blog?page=<%= currentPage + 1 %>" class="pagination-btn bg-white/5 text-gray-400 hover:bg-white/10">Next →</a>
  <% } %>
</div>
<% } %>
<% } %>

<!-- CTA to Video Library -->
<div class="text-center py-10 border-t border-white/5">
  <p class="text-gray-500 text-sm mb-3">Looking for videos to watch?</p>
  <a href="/videos" class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition">
    <i class="fas fa-film"></i> Browse Video Library
  </a>
</div>
