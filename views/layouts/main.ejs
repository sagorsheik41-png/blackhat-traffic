<!DOCTYPE html>
<html lang="en" class="dark">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= typeof title !=='undefined' ? title + ' | ' : '' %>BlackHat Traffic SaaS
  </title>
  <meta name="description" content="All-in-one digital marketing, AI trading, and content creation suite">

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://blackhattraffic.com/">
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title + ' | ' : '' %>BlackHat Traffic SaaS">
  <meta property="og:description"
    content="All-in-one digital marketing, AI trading, and content creation suite. Multi-platform automation and analytics.">
  <meta property="og:image" content="https://blackhattraffic.com/cover.jpg">

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="https://blackhattraffic.com/">
  <meta property="twitter:title"
    content="<%= typeof title !== 'undefined' ? title + ' | ' : '' %>BlackHat Traffic SaaS">
  <meta property="twitter:description" content="All-in-one digital marketing, AI trading, and content creation suite">
  <meta property="twitter:image" content="https://blackhattraffic.com/cover.jpg">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
    rel="stylesheet">
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css">
  <!-- TailwindCSS CDN (dev fallback) -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
  <!-- Global App Utilities -->
  <script src="/js/app.js"></script>
  <!-- Set user role for ad tracker -->
  <script>
    window.userRole = '<%= user && user.role ? user.role : "guest" %>';
  </script>

  <style>
    * {
      font-family: 'Inter', sans-serif !important;
    }

    body {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
    }

    /* Sidebar */
    .sidebar {
      width: 260px;
      transition: transform 0.3s ease;
    }

    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 16px;
      border-radius: 12px;
      color: #94a3b8;
      font-weight: 500;
      font-size: 13px;
      transition: all 0.2s ease;
    }

    .sidebar-link:hover {
      background: rgba(255, 255, 255, 0.08);
      color: #e2e8f0;
    }

    .sidebar-link.active {
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      color: white;
      box-shadow: 0 4px 15px rgba(79, 70, 229, 0.3);
    }

    .sidebar-link i {
      width: 20px;
      text-align: center;
    }

    /* Glass Card */
    .glass-card {
      background: rgba(30, 41, 59, 0.8);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
    }

    /* Mobile sidebar overlay */
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 40;
    }

    .sidebar-overlay.active {
      display: block;
    }

    /* Scrollbar */
    ::-webkit-scrollbar {
      width: 5px;
    }

    ::-webkit-scrollbar-track {
      background: transparent;
    }

    ::-webkit-scrollbar-thumb {
      background: rgba(99, 102, 241, 0.3);
      border-radius: 3px;
    }

    @media (max-width: 1024px) {
      .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        height: 100vh;
        z-index: 50;
        transform: translateX(-100%);
      }

      .sidebar.open {
        transform: translateX(0);
      }
    }
  </style>
</head>

<body class="min-h-screen text-gray-100">

  <!-- Mobile Sidebar Overlay -->
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

  <div class="flex min-h-screen">
    <!-- ═══ Sidebar ═══ -->
    <aside class="sidebar flex-shrink-0 bg-gray-900/95 backdrop-blur-xl border-r border-white/5 flex flex-col"
      id="sidebar">
      <!-- Logo -->
      <div class="p-5 border-b border-white/5">
        <div class="flex items-center gap-3">
          <div
            class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center shadow-lg">
            <i class="fas fa-bolt text-white text-lg"></i>
          </div>
          <div>
            <h1 class="text-base font-bold text-white leading-tight">BlackHat Traffic</h1>
            <span class="text-xs text-indigo-400 font-semibold">SaaS Platform</span>
          </div>
        </div>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 overflow-y-auto p-3 space-y-1">
        <div class="text-xs text-gray-500 font-bold uppercase tracking-wider px-3 py-2">Main</div>

        <a href="/dashboard" class="sidebar-link <%= currentPath === '/dashboard' ? 'active' : '' %>">
          <i class="fas fa-th-large"></i> Dashboard
        </a>

        <div class="text-xs text-gray-500 font-bold uppercase tracking-wider px-3 py-2 mt-4">Tools</div>

        <a href="/tools/adobe-stock"
          class="sidebar-link <%= currentPath.startsWith('/tools/adobe-stock') ? 'active' : '' %>">
          <i class="fas fa-palette"></i> Adobe Stock Suite
        </a>
        <a href="/tools/traffic-pro"
          class="sidebar-link <%= currentPath.startsWith('/tools/traffic-pro') ? 'active' : '' %>">
          <i class="fas fa-chart-line"></i> Traffic Pro
        </a>
        <a href="/tools/trading-bot"
          class="sidebar-link <%= currentPath.startsWith('/tools/trading-bot') ? 'active' : '' %>">
          <i class="fas fa-robot"></i> AI Trading Bot
          <span class="ml-auto text-xs px-2 py-0.5 rounded-full bg-yellow-500/20 text-yellow-400 font-bold">PRO</span>
        </a>
        <a href="/tools/multi-device"
          class="sidebar-link <%= currentPath.startsWith('/tools/multi-device') ? 'active' : '' %>">
          <i class="fas fa-mobile-alt"></i> Multi-Device
        </a>
        <a href="/tools/movie-stream"
          class="sidebar-link <%= currentPath.startsWith('/tools/movie-stream') ? 'active' : '' %>">
          <i class="fas fa-film"></i> Movie Streaming
        </a>
        <a href="/tools/signals" class="sidebar-link <%= currentPath.startsWith('/tools/signals') ? 'active' : '' %>">
          <i class="fas fa-signal"></i> Signal Dashboards
          <span class="ml-auto text-xs px-2 py-0.5 rounded-full bg-yellow-500/20 text-yellow-400 font-bold">PRO</span>
        </a>
        <a href="/tools/youtube" class="sidebar-link <%= currentPath.startsWith('/tools/youtube') ? 'active' : '' %>">
          <i class="fab fa-youtube"></i> YouTube Content
        </a>
        <a href="/tools/link-tools"
          class="sidebar-link <%= currentPath.startsWith('/tools/link-tools') ? 'active' : '' %>">
          <i class="fas fa-link"></i> URL & Link Tools
        </a>
        <a href="/tools/calculator"
          class="sidebar-link <%= currentPath.startsWith('/tools/calculator') ? 'active' : '' %>">
          <i class="fas fa-calculator"></i> View Calculator
        </a>
        <a href="/tools/crypto-mining"
          class="sidebar-link <%= currentPath.startsWith('/tools/crypto-mining') ? 'active' : '' %>">
          <i class="fab fa-ethereum"></i> Crypto Mining
          <span class="ml-auto text-xs px-2 py-0.5 rounded-full bg-purple-500/20 text-purple-400 font-bold">ULT</span>
        </a>

        <div class="text-xs text-gray-500 font-bold uppercase tracking-wider px-3 py-2 mt-4">Video Platform</div>

        <a href="/videos"
          class="sidebar-link <%= currentPath.startsWith('/videos') ? 'active' : '' %>">
          <i class="fas fa-film"></i> Video Library
        </a>
        <a href="/blog"
          class="sidebar-link <%= currentPath.startsWith('/blog') ? 'active' : '' %>">
          <i class="fas fa-newspaper"></i> Blog
        </a>

        <% if (user && user.role==='admin' ) { %>
          <div class="text-xs text-gray-500 font-bold uppercase tracking-wider px-3 py-2 mt-4">Admin</div>
          <a href="/admin" class="sidebar-link <%= currentPath.startsWith('/admin') ? 'active' : '' %>">
            <i class="fas fa-shield-alt"></i> Admin Panel
          </a>
          <% } %>
      </nav>

      <!-- Sidebar Ad Space Container (Hidden from Admin) -->
      <% if (!user || user.role !=='admin' ) { %>
        <div data-sidebar class="flex-grow flex flex-col justify-end p-3 border-t border-white/5 min-h-24">
          <!-- Ads will be injected here by sidebarAdTracker.js -->
        </div>
        <% } %>

          <!-- User Section -->
          <div class="p-3 border-t border-white/5">
            <% if (user) { %>
              <div class="flex items-center gap-3 p-3 rounded-xl bg-white/5">
                <div
                  class="w-9 h-9 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white font-bold text-sm">
                  <%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="text-sm font-semibold text-white truncate">
                    <%= user.name %>
                  </div>
                  <div class="text-xs text-gray-400">
                    <span class="inline-block px-1.5 py-0.5 rounded text-xs font-bold uppercase
                <%= user.tier === 'ultimate' ? 'bg-purple-500/20 text-purple-400' :
                   user.tier === 'pro' ? 'bg-yellow-500/20 text-yellow-400' :
                   'bg-gray-500/20 text-gray-400' %>">
                      <%= user.tier %>
                    </span>
                  </div>
                </div>
                <a href="/auth/logout" class="text-gray-400 hover:text-red-400 transition-colors" title="Logout">
                  <i class="fas fa-sign-out-alt"></i>
                </a>
              </div>
              <% } %>
          </div>
    </aside>

    <!-- ═══ Main Content ═══ -->
    <main class="flex-1 min-w-0">
      <!-- Top Bar -->
      <header class="sticky top-0 z-30 bg-gray-900/80 backdrop-blur-xl border-b border-white/5 px-6 py-3">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button class="lg:hidden text-gray-400 hover:text-white" onclick="toggleSidebar()">
              <i class="fas fa-bars text-xl"></i>
            </button>
            <h2 class="text-lg font-bold text-white">
              <%= typeof title !=='undefined' ? title : 'Dashboard' %>
            </h2>
          </div>
          <div class="flex items-center gap-4">
            <% if (user) { %>
              <a href="/dashboard/upgrade"
                class="text-xs px-3 py-1.5 rounded-full bg-gradient-to-r from-indigo-500 to-purple-600 text-white font-bold hover:shadow-lg hover:shadow-indigo-500/25 transition-all">
                <i class="fas fa-crown mr-1"></i> Upgrade
              </a>
              <% } %>
          </div>
        </div>
      </header>

      <!-- Page Content -->
      <div class="p-6">
        <%- body %>
      </div>
    </main>
  </div>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('active');
    }
  </script>

  <!-- Sidebar Ad Tracker (Duration tracking & view counting) -->
  <script src="/js/sidebarAdTracker.js" defer></script>
  <!-- Live Chat Widget -->
  <script src="/js/liveChat.js" defer></script>
</body>

</html>