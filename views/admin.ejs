<script>
// ─── Video Management ────────────────────────────────────────────
let allVideos = [];
let allCategories = [];

async function loadVideos() {
    try {
        const [vRes, cRes] = await Promise.all([
            fetch('/api/admin/videos'),
            fetch('/api/admin/videos/categories')
        ]);
        const vData = await vRes.json();
        const cData = await cRes.json();
        allVideos = vData.videos || [];
        allCategories = cData.categories || [];
        renderVideoTable(allVideos);
        // Populate category dropdown
        const sel = document.getElementById('vCategory');
        sel.innerHTML = '<option value="">— None —</option>';
        allCategories.forEach(c => {
            sel.innerHTML += `<option value="${c._id}">${c.icon || ''} ${c.name}</option>`;
        });
    } catch(e) { console.error('loadVideos', e); }
}

function renderVideoTable(videos) {
    const tbody = document.getElementById('videoTableBody');
    if (!videos || videos.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center text-gray-500 py-8">No videos yet. Add your first video!</td></tr>';
        return;
    }
    tbody.innerHTML = videos.map(v => `
        <tr class="hover:bg-white/5 transition">
            <td class="py-3 px-3"><img src="${v.thumbnail || ''}" onerror="this.style.display='none'" class="w-16 h-10 object-cover rounded-lg" alt="">${!v.thumbnail ? '<div class="w-16 h-10 bg-indigo-900/30 rounded-lg flex items-center justify-center"><i class="fas fa-film text-xs text-indigo-400"></i></div>' : ''}</td>
            <td class="py-3 px-3">
                <div class="text-xs font-bold text-white line-clamp-1">${v.title}</div>
                <div class="text-[10px] text-gray-500">${v.category?.name || 'No category'} ${v.isFeatured ? '⭐' : ''} ${v.isTrending ? '🔥' : ''}</div>
            </td>
            <td class="py-3 px-3 text-center text-xs text-indigo-300">${(v.stats?.views || 0).toLocaleString()}</td>
            <td class="py-3 px-3 text-center text-xs text-green-300">${(v.stats?.redirectClicks || 0).toLocaleString()}</td>
            <td class="py-3 px-3 text-center"><span class="text-[10px] px-2 py-0.5 rounded-full font-bold ${v.isPublished ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400'}">${v.isPublished ? 'Live' : 'Draft'}</span></td>
            <td class="py-3 px-3 text-right">
                <a href="/videos/${v.slug}" target="_blank" class="p-1.5 text-gray-400 hover:text-cyan-400 transition" title="View"><i class="fas fa-external-link-alt text-xs"></i></a>
                <button onclick="editVideo('${v._id}')" class="p-1.5 text-gray-400 hover:text-indigo-400 transition" title="Edit"><i class="fas fa-edit text-xs"></i></button>
                <button onclick="deleteVideo('${v._id}')" class="p-1.5 text-gray-400 hover:text-red-400 transition" title="Delete"><i class="fas fa-trash text-xs"></i></button>
            </td>
        </tr>
    `).join('');
}

function filterVideoTable() {
    const q = document.getElementById('videoSearchInput').value.toLowerCase();
    renderVideoTable(allVideos.filter(v => v.title.toLowerCase().includes(q)));
}

function openVideoModal(v) {
    document.getElementById('videoModalTitle').textContent = v ? 'Edit Video' : 'Add Video';
    document.getElementById('videoId').value = v?._id || '';
    document.getElementById('vTitle').value = v?.title || '';
    document.getElementById('vTeraboxLink').value = v?.teraboxLink || '';
    document.getElementById('vThumbnail').value = v?.thumbnail || '';
    document.getElementById('vPreviewVideoUrl').value = v?.previewVideoUrl || '';
    document.getElementById('vCategory').value = v?.category?._id || '';
    document.getElementById('vTags').value = (v?.tags || []).join(', ');
    document.getElementById('vDescription').value = v?.description || '';
    document.getElementById('vSeoTitle').value = v?.seoTitle || '';
    document.getElementById('vSeoDescription').value = v?.seoDescription || '';
    document.getElementById('vIsFeatured').checked = !!v?.isFeatured;
    document.getElementById('vIsTrending').checked = !!v?.isTrending;
    document.getElementById('vIsPublished').checked = v ? !!v.isPublished : true;
    document.getElementById('videoModal').classList.remove('hidden');
}
function closeVideoModal() { document.getElementById('videoModal').classList.add('hidden'); }
function editVideo(id) { openVideoModal(allVideos.find(v => v._id === id)); }
async function deleteVideo(id) {
    if (!confirm('Delete this video and its analytics?')) return;
    await fetch(`/api/admin/videos/${id}`, { method: 'DELETE' });
    loadVideos();
}
async function saveVideo(e) {
    e.preventDefault();
    const id = document.getElementById('videoId').value;
    const body = {
        title: document.getElementById('vTitle').value,
        teraboxLink: document.getElementById('vTeraboxLink').value,
        thumbnail: document.getElementById('vThumbnail').value,
        previewVideoUrl: document.getElementById('vPreviewVideoUrl').value,
        category: document.getElementById('vCategory').value,
        tags: document.getElementById('vTags').value,
        description: document.getElementById('vDescription').value,
        seoTitle: document.getElementById('vSeoTitle').value,
        seoDescription: document.getElementById('vSeoDescription').value,
        isFeatured: document.getElementById('vIsFeatured').checked,
        isTrending: document.getElementById('vIsTrending').checked,
        isPublished: document.getElementById('vIsPublished').checked,
    };
    const url = id ? `/api/admin/videos/${id}` : '/api/admin/videos';
    const method = id ? 'PUT' : 'POST';
    const res = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
    const data = await res.json();
    if (data.success) { closeVideoModal(); loadVideos(); if(typeof showToast !== 'undefined') showToast('Video saved!', 'success'); }
    else if(typeof showToast !== 'undefined') showToast(data.error || 'Error', 'error');
}

// ─── Blog Management ─────────────────────────────────────────────
let allPosts = [];
async function loadBlog() {
    try {
        const res = await fetch('/api/admin/blog');
        const data = await res.json();
        allPosts = data.posts || [];
        const tbody = document.getElementById('blogTableBody');
        tbody.innerHTML = allPosts.map(p => `
            <tr class="hover:bg-white/5 transition">
                <td class="py-3 px-3"><div class="text-xs font-bold text-white line-clamp-1">${p.title}</div><div class="text-[10px] text-gray-500">${new Date(p.createdAt).toLocaleDateString()}</div></td>
                <td class="py-3 px-3 text-center text-xs text-indigo-300">${(p.views || 0).toLocaleString()}</td>
                <td class="py-3 px-3 text-center"><span class="text-[10px] px-2 py-0.5 rounded-full font-bold ${p.isPublished ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400'}">${p.isPublished ? 'Published' : 'Draft'}</span></td>
                <td class="py-3 px-3 text-right">
                    <a href="/blog/${p.slug}" target="_blank" class="p-1.5 text-gray-400 hover:text-cyan-400 transition"><i class="fas fa-external-link-alt text-xs"></i></a>
                    <button onclick="editBlog('${p._id}')" class="p-1.5 text-gray-400 hover:text-indigo-400 transition"><i class="fas fa-edit text-xs"></i></button>
                    <button onclick="deleteBlog('${p._id}')" class="p-1.5 text-gray-400 hover:text-red-400 transition"><i class="fas fa-trash text-xs"></i></button>
                </td>
            </tr>
        `).join('') || '<tr><td colspan="4" class="text-center text-gray-500 py-8">No posts yet.</td></tr>';
    } catch(e) { console.error('loadBlog', e); }
}
function openBlogModal(p) {
    document.getElementById('blogModalTitle').textContent = p ? 'Edit Post' : 'New Blog Post';
    document.getElementById('blogPostId').value = p?._id || '';
    document.getElementById('bTitle').value = p?.title || '';
    document.getElementById('bFeaturedImage').value = p?.featuredImage || '';
    document.getElementById('bContent').value = p?.content || '';
    document.getElementById('bMetaDescription').value = p?.metaDescription || '';
    document.getElementById('bSeoKeywords').value = (p?.seoKeywords || []).join(', ');
    document.getElementById('bIsPublished').checked = p ? !!p.isPublished : true;
    document.getElementById('blogModal').classList.remove('hidden');
}
function closeBlogModal() { document.getElementById('blogModal').classList.add('hidden'); }
function editBlog(id) { openBlogModal(allPosts.find(p => p._id === id)); }
async function deleteBlog(id) {
    if (!confirm('Delete this blog post?')) return;
    await fetch(`/api/admin/blog/${id}`, { method: 'DELETE' });
    loadBlog();
}
async function saveBlog(e) {
    e.preventDefault();
    const id = document.getElementById('blogPostId').value;
    const body = {
        title: document.getElementById('bTitle').value,
        featuredImage: document.getElementById('bFeaturedImage').value,
        content: document.getElementById('bContent').value,
        metaDescription: document.getElementById('bMetaDescription').value,
        seoKeywords: document.getElementById('bSeoKeywords').value,
        isPublished: document.getElementById('bIsPublished').checked,
    };
    const url = id ? `/api/admin/blog/${id}` : '/api/admin/blog';
    const method = id ? 'PUT' : 'POST';
    const res = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
    const data = await res.json();
    if (data.success) { closeBlogModal(); loadBlog(); if(typeof showToast !== 'undefined') showToast('Post saved!', 'success'); }
    else if(typeof showToast !== 'undefined') showToast(data.error || 'Error', 'error');
}

// ─── Affiliate Management ────────────────────────────────────────
let allAffiliates = [];
async function loadAffiliates() {
    try {
        const res = await fetch('/api/admin/affiliates');
        const data = await res.json();
        allAffiliates = data.affiliates || [];
        const tbody = document.getElementById('affiliateTableBody');
        tbody.innerHTML = allAffiliates.map(a => `
            <tr class="hover:bg-white/5 transition">
                <td class="py-3 px-3"><div class="text-xs font-bold text-white">${a.title}</div><div class="text-[10px] text-orange-400 uppercase font-bold">${a.type}</div></td>
                <td class="py-3 px-3 text-xs text-gray-400 max-w-[180px] truncate">${a.url}</td>
                <td class="py-3 px-3 text-center text-xs text-green-300">${(a.clicks || 0).toLocaleString()}</td>
                <td class="py-3 px-3 text-center">
                    <span class="text-[10px] px-2 py-0.5 rounded-full font-bold ${a.isActive ? 'bg-green-500/20 text-green-400' : 'bg-gray-500/20 text-gray-400'}">${a.isActive ? 'Active' : 'Off'}</span>
                </td>
                <td class="py-3 px-3 text-right">
                    <button onclick="editAffiliate('${a._id}')" class="p-1.5 text-gray-400 hover:text-indigo-400 transition"><i class="fas fa-edit text-xs"></i></button>
                    <button onclick="toggleAffiliate('${a._id}')" class="p-1.5 text-gray-400 hover:text-yellow-400 transition"><i class="fas fa-toggle-on text-xs"></i></button>
                    <button onclick="deleteAffiliate('${a._id}')" class="p-1.5 text-gray-400 hover:text-red-400 transition"><i class="fas fa-trash text-xs"></i></button>
                </td>
            </tr>
        `).join('') || '<tr><td colspan="5" class="text-center text-gray-500 py-8">No affiliates yet.</td></tr>';
    } catch(e) { console.error('loadAffiliates', e); }
}
function openAffiliateModal(a) {
    document.getElementById('affiliateModalTitle').textContent = a ? 'Edit Offer' : 'Add Affiliate Offer';
    document.getElementById('affiliateId').value = a?._id || '';
    document.getElementById('aTitle').value = a?.title || '';
    document.getElementById('aType').value = a?.type || 'offer';
    document.getElementById('aUrl').value = a?.url || '';
    document.getElementById('aImageUrl').value = a?.imageUrl || '';
    document.getElementById('aDescription').value = a?.description || '';
    document.getElementById('aTargetCountries').value = (a?.targetCountries || []).join(', ');
    document.getElementById('aDisplayOrder').value = a?.displayOrder || 0;
    document.getElementById('affiliateModal').classList.remove('hidden');
}
function closeAffiliateModal() { document.getElementById('affiliateModal').classList.add('hidden'); }
function editAffiliate(id) { openAffiliateModal(allAffiliates.find(a => a._id === id)); }
async function toggleAffiliate(id) {
    await fetch(`/api/admin/affiliates/${id}/toggle`, { method: 'POST' });
    loadAffiliates();
}
async function deleteAffiliate(id) {
    if (!confirm('Delete affiliate?')) return;
    await fetch(`/api/admin/affiliates/${id}`, { method: 'DELETE' });
    loadAffiliates();
}
async function saveAffiliate(e) {
    e.preventDefault();
    const id = document.getElementById('affiliateId').value;
    const body = {
        title: document.getElementById('aTitle').value,
        type: document.getElementById('aType').value,
        url: document.getElementById('aUrl').value,
        imageUrl: document.getElementById('aImageUrl').value,
        description: document.getElementById('aDescription').value,
        targetCountries: document.getElementById('aTargetCountries').value,
        displayOrder: document.getElementById('aDisplayOrder').value,
    };
    const url = id ? `/api/admin/affiliates/${id}` : '/api/admin/affiliates';
    const method = id ? 'PUT' : 'POST';
    const res = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
    const data = await res.json();
    if (data.success) { closeAffiliateModal(); loadAffiliates(); if(typeof showToast !== 'undefined') showToast('Affiliate saved!', 'success'); }
    else if(typeof showToast !== 'undefined') showToast(data.error || 'Error', 'error');
}

// ─── Video Analytics ─────────────────────────────────────────────
async function loadVideoAnalytics() {
    try {
        const res = await fetch('/api/admin/videos/analytics/summary');
        const data = await res.json();
        if (!data.success) return;
        document.getElementById('va-views').textContent = (data.totalViews || 0).toLocaleString();
        document.getElementById('va-popups').textContent = (data.totalPopupClicks || 0).toLocaleString();
        document.getElementById('va-redirects').textContent = (data.totalRedirects || 0).toLocaleString();
        document.getElementById('va-rate').textContent = (data.conversionRate || 0) + '%';
        document.getElementById('va-top-videos').innerHTML = (data.topVideos || []).map((v,i) =>
            `<div class="flex items-center gap-3 p-2 rounded-xl bg-white/4 border border-white/5">
                <span class="text-xs font-black text-gray-500 w-5">${i+1}</span>
                <div class="flex-1 min-w-0"><div class="text-xs font-bold text-white truncate">${v.title}</div></div>
                <div class="text-xs text-indigo-300 font-bold">${(v.stats?.views||0).toLocaleString()} views</div>
            </div>`
        ).join('') || '<p class="text-gray-500 text-xs">No data yet.</p>';
        document.getElementById('va-top-countries').innerHTML = (data.topCountries || []).map((c,i) =>
            `<div class="flex items-center gap-3 p-2 rounded-xl bg-white/4 border border-white/5">
                <span class="text-xs font-black text-gray-500 w-5">${i+1}</span>
                <div class="flex-1 text-xs font-bold text-white">${c._id || 'Unknown'}</div>
                <div class="text-xs text-purple-300 font-bold">${c.count.toLocaleString()}</div>
            </div>`
        ).join('') || '<p class="text-gray-500 text-xs">No data yet.</p>';
    } catch(e) { console.error('loadVideoAnalytics', e); }
}

// ─── Hook into existing tab switch ───────────────────────────────
const _origSwitchTab = window.switchTab;
window.switchTab = function(tabId) {
    if (typeof _origSwitchTab === 'function') _origSwitchTab(tabId);
    if (tabId === 'videos' && allVideos.length === 0) loadVideos();
    if (tabId === 'blog' && allPosts.length === 0) loadBlog();
    if (tabId === 'affiliates' && allAffiliates.length === 0) loadAffiliates();
    if (tabId === 'vid-analytics') loadVideoAnalytics();
};
</script>

<!-- Edit User Modal -->
<div id="editUserModal" class="hidden fixed inset-0 z-50 bg-black/80 backdrop-blur-sm items-center justify-center p-4">
    <div class="glass p-8 rounded-3xl border border-white/10 w-full max-w-md animate-in fade-in zoom-in duration-300">
        <h3 class="text-xl font-bold text-white mb-6">Edit User Node</h3>
        <form id="editUserForm" class="space-y-4">
            <input type="hidden" id="editUserId">
            <div class="space-y-1">
                <label class="text-[10px] font-bold text-gray-500 uppercase">Full Name</label>
                <input type="text" id="editUserName" required
                    class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:border-indigo-500 outline-none">
            </div>
            <div class="space-y-1">
                <label class="text-[10px] font-bold text-gray-500 uppercase">Email Address</label>
                <input type="email" id="editUserEmail" required
                    class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:border-indigo-500 outline-none">
            </div>
            <div class="space-y-1">
                <label class="text-[10px] font-bold text-gray-500 uppercase">Phone Number</label>
                <input type="text" id="editUserPhone"
                    class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:border-indigo-500 outline-none">
            </div>
            <div class="flex gap-3 pt-2">
                <button type="button" onclick="closeEditModal()"
                    class="flex-1 py-3 bg-white/5 hover:bg-white/10 text-white font-bold rounded-xl transition-all border border-white/10">Cancel</button>
                <button type="submit"
                    class="flex-1 py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-xl transition-all shadow-lg shadow-indigo-600/20">Save
                    Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
    // Dynamic width application
    document.querySelectorAll('.dynamic-width').forEach(el => {
        el.style.width = el.getAttribute('data-width');
    });

    // Tab Logic
    function switchTab(tabId) {
        document.querySelectorAll('.tab-pane').forEach(p => p.classList.add('hidden'));
        document.getElementById(`pane-${tabId}`).classList.remove('hidden');
        document.querySelectorAll('.tab-btn').forEach(b => {
            b.classList.remove('active', 'text-white', 'bg-indigo-600');
            b.classList.add('text-gray-500');
        });
        const activeBtn = document.getElementById(`tab-${tabId}`);
        if (activeBtn) {
            activeBtn.classList.add('active', 'text-white', 'bg-indigo-600');
            activeBtn.classList.remove('text-gray-500');
        }
        localStorage.setItem('adminActiveTab', tabId);
    }

    // Initialize tab from localStorage
    document.addEventListener('DOMContentLoaded', () => {
        const savedTab = localStorage.getItem('adminActiveTab') || 'overview';
        switchTab(savedTab);
    });

    // Chart init - using encoded string to prevent IDE "Expression expected" syntax errors
    const growthDataRaw = '<%= encodeURIComponent(JSON.stringify(stats.growthData || [])) %>';
    const growthData = JSON.parse(decodeURIComponent(growthDataRaw));

    const ctx = document.getElementById('growthChart').getContext('2d');
    if (ctx) {
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: growthData.map(d => d._id),
                datasets: [{
                    label: 'New Nodes',
                    data: growthData.map(d => d.count),
                    borderColor: '#6366f1',
                    borderWidth: 3,
                    tension: 0.4,
                    pointBackgroundColor: '#6366f1',
                    fill: true,
                    backgroundColor: 'rgba(99, 102, 241, 0.1)'
                }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)' } },
                    x: { grid: { display: false } }
                }
            }
        });
    }

    // Payment Actions
    async function approvePayment(id) {
        if (!confirm('Approve payment and upgrade user?')) return;
        try {
            const res = await fetch(`/admin/payments/${id}/approve`, { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                if (typeof showToast !== 'undefined') showToast(data.message, 'success');
                location.reload();
            } else {
                if (typeof showToast !== 'undefined') showToast(data.error || 'Update failed', 'error');
                else alert(data.error);
            }
        } catch (err) {
            console.error(err);
        }
    }

    async function rejectPayment(id) {
        const note = prompt('Rejection reason (optional):');
        if (note === null) return;
        try {
            const res = await fetch(`/admin/payments/${id}/reject`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ note })
            });
            const data = await res.json();
            if (data.success) location.reload();
        } catch (err) {
            console.error(err);
        }
    }

    async function updateSettings(e, type) {
        e.preventDefault();
        const formData = new FormData(e.target);
        const body = { [type]: Object.fromEntries(formData.entries()) };
        try {
            const res = await fetch('/admin/settings/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            const data = await res.json();
            if (data.success) {
                if (typeof showToast !== 'undefined') showToast(data.message, 'success');
                else alert(data.message);
            }
        } catch (err) {
            console.error(err);
        }
    }

    async function toggleCurrency() {
        // Enclosed in string to prevent IDE parse errors
        var isBdtActive = ('<%= !!settings.useBDT %>' === 'true');
        var switchBdtTo = !isBdtActive;
        try {
            const res = await fetch('/admin/settings/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ useBDT: switchBdtTo })
            });
            const data = await res.json();
            if (data.success) location.reload();
        } catch (err) {
            console.error(err);
        }
    }

    async function toggleGlobalSidebarAds() {
        try {
            const res = await fetch('/admin/settings/ad-toggle', { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                const btn = document.getElementById('global-ad-toggle');
                if (data.enabled) {
                    btn.classList.remove('bg-gray-600', 'text-gray-300');
                    btn.classList.add('bg-green-600', 'text-white');
                    btn.innerText = 'ENABLED';
                } else {
                    btn.classList.remove('bg-green-600', 'text-white');
                    btn.classList.add('bg-gray-600', 'text-gray-300');
                    btn.innerText = 'DISABLED';
                }
                if (typeof showToast !== 'undefined') showToast(`Sidebar ads ${data.enabled ? 'enabled' : 'disabled'} globally`, 'success');
            }
        } catch (err) {
            console.error(err);
        }
    }

    // User management scripts
    function openEditModal(encodedUser) {
        const u = JSON.parse(decodeURIComponent(encodedUser));
        document.getElementById('editUserId').value = u._id;
        document.getElementById('editUserName').value = u.name;
        document.getElementById('editUserEmail').value = u.email;
        document.getElementById('editUserPhone').value = u.phone || '';
        document.getElementById('editUserModal').classList.remove('hidden');
        document.getElementById('editUserModal').classList.add('flex');
    }

    function closeEditModal() {
        document.getElementById('editUserModal').classList.add('hidden');
        document.getElementById('editUserModal').classList.remove('flex');
    }

    document.getElementById('editUserForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = document.getElementById('editUserId').value;
        const body = {
            name: document.getElementById('editUserName').value,
            email: document.getElementById('editUserEmail').value,
            phone: document.getElementById('editUserPhone').value
        };
        try {
            const res = await fetch(`/admin/users/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            const data = await res.json();
            if (data.success) {
                if (typeof showToast !== 'undefined') showToast('User node updated successfully', 'success');
                location.reload();
            } else {
                if (typeof showToast !== 'undefined') showToast(data.error || 'Update failed', 'error');
            }
        } catch (err) {
            console.error(err);
        }
    });

    async function updateTier(id, tier) {
        await fetch(`/admin/users/${id}/tier`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tier })
        });
        location.reload();
    }

    async function toggleUser(id) {
        await fetch(`/admin/users/${id}/toggle`, { method: 'POST' });
        location.reload();
    }

    async function deleteUser(id) {
        if (confirm('Delete user?')) {
            await fetch(`/admin/users/${id}`, { method: 'DELETE' });
            location.reload();
        }
    }

    async function resetTrafficStats(id) {
        if (!confirm('Are you sure you want to reset all Traffic Pro stats for this user?')) return;
        try {
            const res = await fetch(`/admin/user/${id}/reset-traffic-pro`, { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                if (typeof showToast !== 'undefined') showToast('Traffic stats reset to zero', 'success');
                else alert('Stats reset successfully');
                location.reload();
            }
        } catch (err) {
            console.error(err);
        }
    }

    // Search logic
    const userSearch = document.getElementById('userSearch');
    if (userSearch) {
        userSearch.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase();
            document.querySelectorAll('.user-row').forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(query) ? '' : 'none';
            });
        });
    }
</script>

